  file_change {
    absolute_path_uri: "file:///src/components/DesignGuideView.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \"react\";\nimport { DesignTheme } from \"../types\";\nimport { Copy, Check, Palette, Sparkles, AlertCircle, RefreshCw } from \"lucide-react\";\n\ninterface DesignGuideProps {\n  activeTheme: DesignTheme;\n}\n\nexport default function DesignGuideView({ activeTheme }: DesignGuideProps) {\n  const [copiedColor, setCopiedColor] = useState<string | null>(null);\n\n  const handleCopyColor = (hex: string) => {\n    navigator.clipboard.writeText(hex);\n    setCopiedColor(hex);\n    setTimeout(() => setCopiedColor(null), 1500);\n  };\n\n  return (\n    <div className=\"bg-white rounded-2xl border border-slate-100 shadow-sm p-6 overflow-y-auto max-h-[85vh] flex flex-col gap-6\" id=\"design-guide-container\">\n      {/* Header */}\n      <div>\n        <div className=\"flex items-center gap-2 text-teal-600 font-medium text-sm mb-1\">\n          <Sparkles className=\"w-4 h-4\" />\n          <span>\353\260\200\353\240\210\353\213\210\354\226\274 & Z\354\204\270\353\214\200 \353\247\236\354\266\244\355\230\225 \352\260\200\354\235\264\353\223\234</span>\n        </div>\n        <h2 className=\"text-xl font-bold text-slate-800 tracking-tight flex items-center gap-2\">\n          <Palette className=\"w-5 h-5 text-slate-600\" />\n          \353\257\270\353\246\254\354\272\224\353\262\204\354\212\244 & Canva \354\240\234\354\236\221 \352\260\200\354\235\264\353\223\234\n        </h2>\n        <p className=\"text-xs text-slate-500 mt-1\">\n          \355\225\264\353\213\271 \355\205\215\354\212\244\355\212\270\353\245\274 \354\235\270\354\212\244\355\203\200 \354\212\244\355\206\240\353\246\254 \353\260\217 \353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264 \354\271\264\353\223\234\353\211\264\354\212\244\353\241\234 \354\240\234\354\236\221\355\225\240 \353\225\214 \354\234\240\354\232\251\355\225\234 \354\240\204\353\254\270\352\260\200 \355\214\201\354\236\205\353\213\210\353\213\244.\n        </p>\n      </div>\n\n      {/* Recommended Theme Concept */}\n      <div className=\"bg-slate-50 rounded-xl p-4 border border-slate-100\">\n        <h3 className=\"font-semibold text-sm text-slate-700 flex items-center gap-1.5 mb-2\">\n          <span>\360\237\216\250</span> \355\230\204\354\236\254 \354\273\250\354\205\211: <strong className=\"text-slate-900\">{activeTheme.name}</strong>\n        </h3>\n        <p className=\"text-xs text-slate-600 leading-relaxed\">\n          {activeTheme.concept}\n        </p>\n        <div className=\"mt-3 text-[10px] text-slate-400 flex items-center gap-1\">\n          <AlertCircle className=\"w-3.5 h-3.5 text-slate-400\" />\n          <span>\352\260\201 \354\203\211\352\271\224 \354\233\220\354\235\204 \355\201\264\353\246\255\355\225\230\353\251\264 HEX \354\203\211\354\203\201 \354\275\224\353\223\234\352\260\200 \355\201\264\353\246\275\353\263\264\353\223\234\354\227\220 \353\263\265\354\202\254\353\220\251\353\213\210\353\213\244!</span>\n        </div>\n      </div>\n\n      {/* Color Palette Choice */}\n      <div>\n        <h3 className=\"font-bold text-xs text-slate-500 tracking-wider uppercase mb-3\">\n          \354\266\224\354\262\234 \354\240\204\354\232\251 \354\273\254\353\237\254 \355\214\224\353\240\210\355\212\270 (HEX Codes)\n        </h3>\n        <div className=\"grid grid-cols-2 gap-3\">\n          {activeTheme.colors.map((color, index) => (\n            <button\n              key={index}\n              onClick={() => handleCopyColor(color.hex)}\n              className=\"flex items-center gap-3 p-2.5 rounded-xl border border-slate-100 bg-white hover:bg-slate-50 hover:border-slate-300 transition-all text-left relative focus:outline-none focus:ring-2 focus:ring-teal-500\"\n              title={`${color.hex} \353\263\265\354\202\254\355\225\230\352\270\260`}\n              id={`color-swatch-${index}`}\n            >\n              <div className={`w-8 h-8 rounded-full ${color.tailwind} border border-black/5 shadow-inner flex items-center justify-center shrink-0`}>\n                {copiedColor === color.hex && (\n                  <Check className=\"w-4 h-4 text-white drop-shadow-md\" />\n                )}\n              </div>\n              <div className=\"min-w-0 flex-1\">\n                <div className=\"text-[11px] font-semibold text-slate-800 truncate\">{color.name}</div>\n                <div className=\"font-mono text-[10px] text-slate-400 truncate flex items-center gap-1\">\n                  <span>{color.hex}</span>\n                  <Copy className=\"w-2.5 h-2.5 shrink-0 opacity-50 group-hover:opacity-100\" />\n                </div>\n              </div>\n            </button>\n          ))}\n        </div>\n      </div>\n\n      {/* Font pairing guidelines */}\n      <div>\n        <h3 className=\"font-bold text-xs text-slate-500 tracking-wider uppercase mb-3\">\n          \354\266\224\354\262\234 \355\217\260\355\212\270 \355\216\230\354\226\264\353\247\201 (Font Pairing)\n        </h3>\n        <div className=\"flex flex-col gap-3\">\n          {activeTheme.recommendedFonts.map((font, idx) => (\n            <div key={idx} className=\"p-3 bg-slate-50 rounded-xl border border-slate-100\">\n              <span className=\"text-[10px] font-bold text-teal-600 bg-teal-50 px-2 py-0.5 rounded-full inline-block mb-1\">\n                {font.target}\n              </span>\n              <h4 className=\"font-bold text-xs text-slate-800 mb-0.5\">\n                {font.name}\n              </h4>\n              <p className=\"text-[11px] text-slate-500 leading-relaxed\">\n                {font.details}\n              </p>\n            </div>\n          ))}\n        </div>\n      </div>\n\n      {/* Layout Tip */}\n      <div>\n        <h3 className=\"font-bold text-xs text-slate-500 tracking-wider uppercase mb-3\">\n          \352\260\220\352\260\201\354\240\201\354\235\270 Z\354\204\270\353\214\200 \353\224\224\354\236\220\354\235\270 \352\277\200\355\214\201 3\352\260\200\354\247\200\n        </h3>\n        <ul className=\"flex flex-col gap-3 text-xs text-slate-600\">\n          <li className=\"flex gap-2.5\">\n            <span className=\"text-teal-600 font-bold shrink-0\">01</span>\n            <div>\n              <strong className=\"text-slate-800 block\">\354\227\254\353\260\261(White Space)\354\235\204 \354\202\254\353\236\221\355\225\230\354\204\270\354\232\224</strong>\n              <p className=\"text-[11px] text-slate-500 mt-0.5 leading-relaxed\">\n                \352\270\200\354\224\250\352\260\200 \352\275\211 \354\260\250 \354\236\210\354\234\274\353\251\264 \'\354\230\254\353\223\234\'\355\225\264 \353\263\264\354\236\205\353\213\210\353\213\244. \354\232\224\354\206\214\354\231\200 \352\262\275\352\263\204\354\204\240 \354\202\254\354\235\264\354\227\220 \354\212\244\353\247\210\355\212\270\355\217\260 \353\221\220 \354\206\220\352\260\200\353\235\275 \353\221\220\352\273\230 \354\240\225\353\217\204\354\235\230 \355\231\224\353\251\264 \354\227\254\353\260\261\354\235\204 \352\263\274\352\260\220\355\236\210 \353\263\264\354\236\245\355\225\264 \354\243\274\354\204\270\354\232\224.\n              </p>\n            </div>\n          </li>\n          <li className=\"flex gap-2.5\">\n            <span className=\"text-teal-600 font-bold shrink-0\">02</span>\n            <div>\n              <strong className=\"text-slate-800 block\">\354\235\270\354\212\244\355\203\200\354\232\251 \353\240\210\354\235\264\354\225\204\354\233\203 \353\266\204\355\225\240</strong>\n              <p className=\"text-[11px] text-slate-500 mt-0.5 leading-relaxed\">\n                \354\235\264 \355\205\215\354\212\244\355\212\270 \354\240\204\354\262\264\353\245\274 \355\225\234 \354\212\254\353\235\274\354\235\264\353\223\234\354\227\220 \353\213\244 \353\204\243\352\270\260\353\263\264\353\213\244\353\212\224, <strong>1\354\236\245: \354\235\270\355\212\270\353\241\234 & \354\260\254\354\226\221 \353\252\251\353\241\235, 2\354\236\245: \354\230\210\353\260\260 \354\210\234\354\204\234 \353\260\217 \353\247\220\354\224\200, 3\354\236\245: \354\235\270\354\212\244\355\203\200 \354\206\214\354\213\235 & \354\262\264\355\201\254\353\246\254\354\212\244\355\212\270</strong> \355\230\225\354\213\235\354\234\274\353\241\234 3\354\236\245 \353\266\204\355\225\240 \354\271\264\353\223\234\353\211\264\354\212\244\353\241\234 \354\230\254\353\246\254\353\251\264 \354\235\270\354\212\244\355\203\200 \355\224\274\353\223\234 \353\205\270\354\266\234 \354\265\234\354\240\201\354\235\264 \353\220\251\353\213\210\353\213\244.\n              </p>\n            </div>\n          </li>\n          <li className=\"flex gap-2.5\">\n            <span className=\"text-teal-600 font-bold shrink-0\">03</span>\n            <div>\n              <strong className=\"text-slate-800 block\">\355\205\215\354\212\244\355\212\270 \353\263\265\354\202\254 \353\260\217 \355\231\234\354\232\251</strong>\n              <p className=\"text-[11px] text-slate-500 mt-0.5 leading-relaxed\">\n                \354\231\274\354\252\275 \354\240\204\354\206\241 \354\203\201\354\236\220 \355\225\230\353\213\250\354\235\230 \353\262\204\355\212\274\354\235\204 \354\202\254\354\232\251\355\225\264 \354\240\225\352\260\210\355\225\230\352\262\214 \353\263\200\355\231\230\353\220\234 KakaoTalk\354\232\251 \354\235\274\352\264\204 \353\251\224\354\213\234\354\247\200\353\245\274 \353\260\233\354\225\204 \353\260\224\353\241\234 \353\260\234\354\206\241\355\225\264 \354\262\255\353\205\204\353\223\244\354\235\230 \354\260\270\354\227\254\354\234\250\354\235\204 \353\206\222\354\235\264\354\204\270\354\232\224!\n              </p>\n            </div>\n          </li>\n        </ul>\n      </div>\n\n      {/* Real-time preview note */}\n      <div className=\"bg-amber-50/50 border border-amber-100 rounded-xl p-3.5 flex gap-2.5\">\n        <AlertCircle className=\"w-4 h-4 text-amber-600 shrink-0 mt-0.5\" />\n        <div className=\"text-[11px] text-amber-800 leading-relaxed\">\n          <span className=\"font-bold\">\354\213\244\354\213\234\352\260\204 \355\205\214\353\247\210 \353\257\270\353\246\254\353\263\264\352\270\260 \354\227\260\353\217\231:</span> \354\233\271\354\235\230 \354\244\221\354\225\231 \353\252\250\353\260\224\354\235\274 \353\257\270\353\246\254\353\263\264\352\270\260 \355\205\214\353\247\210\353\245\274 \354\240\204\355\231\230\355\225\230\353\251\264, \354\235\264 \352\260\200\354\235\264\353\223\234 \353\266\201\354\235\230 \354\273\254\353\237\254 \353\260\217 \355\217\260\355\212\270 \355\216\230\354\226\264\353\247\201 \354\240\234\354\225\210 \353\252\205\353\213\250\353\217\204 \354\236\220\353\217\231 \353\247\244\354\271\255\353\220\230\354\226\264 \354\246\211\354\213\234 \355\231\234\354\232\251 \352\260\200\353\212\245\355\225\234 \354\275\224\353\223\234\352\260\200 \355\221\234\354\213\234\353\220\251\353\213\210\353\213\244!\n        </div>\n      </div>\n    </div>\n  );\n}\n"
    }
