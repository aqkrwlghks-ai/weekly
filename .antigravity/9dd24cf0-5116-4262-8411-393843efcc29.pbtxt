        lines {
          text: "    content: \"\353\202\264\354\235\274 \354\232\260\353\246\254\354\235\230 \354\230\201\355\230\274\354\235\204 \354\235\200\355\230\234\353\241\234 \352\260\200\353\223\235 \354\261\204\354\232\270 \354\230\210\353\260\260\352\260\200 \354\244\200\353\271\204\353\220\230\354\226\264 \354\236\210\354\226\264. \354\232\260\353\246\254\352\260\200 \353\234\250\352\262\201\352\262\214 \354\260\254\354\226\221\355\225\240 \353\225\214 \354\236\204\355\225\230\354\213\244 \355\225\230\353\212\230\354\235\230 \354\261\204\354\232\260\354\213\254\354\235\204 \352\270\260\353\214\200\355\225\264\353\263\264\354\236\220. \352\270\260\354\201\234 \353\247\210\354\235\214\352\263\274 \352\261\264\352\260\225\355\225\234 \353\257\270\354\206\214\353\241\234 \353\202\264\354\235\274 \353\260\230\352\260\221\352\262\214 \354\235\270\354\202\254\355\225\230\354\236\220!\""
