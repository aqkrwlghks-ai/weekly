        lines {
          text: "    content: \"\353\210\204\352\265\254\354\227\220\352\262\214\353\217\204 \355\204\270\354\226\264\353\206\223\354\247\200 \353\252\273\355\225\234 \353\247\210\354\235\214\354\235\230 \354\247\220\354\235\264 \354\236\210\353\213\244\353\251\264 \353\202\264\354\235\274 \354\240\204\353\266\200 \354\230\210\353\260\260 \353\223\234\353\246\254\353\212\224 \352\260\200\354\232\264\353\215\260 \354\217\237\354\225\204\353\206\223\352\270\270 \353\260\224\353\236\204\352\262\214. \354\243\274\353\213\230\354\235\200 \354\226\270\354\240\234\353\202\230 \353\204\210\354\235\230 \354\236\221\354\235\200 \354\213\240\354\235\214\354\227\220\353\217\204 \352\267\200 \352\270\260\354\232\270\354\235\264\354\213\234\353\213\210\352\271\214. \354\204\244\353\240\210\353\212\224 \353\247\230\354\234\274\353\241\234 \353\204\210\353\245\274 \352\270\260\353\213\244\353\240\244. \360\237\225\212\357\270\217\""
