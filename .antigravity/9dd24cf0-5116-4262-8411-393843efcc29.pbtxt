        lines {
          text: "    concept: \"\354\230\244\354\247\201 \354\243\274\353\213\230\354\235\230 \354\236\204\354\236\254\354\231\200 \353\202\264 \353\202\264\353\251\264\354\235\230 \353\254\265\354\203\201\354\227\220 \352\263\240\353\217\204\353\241\234 \353\266\210\354\235\204 \353\260\235\355\236\210\353\212\224 \354\225\204\354\232\260\353\235\274 \353\254\264\353\223\234. \353\224\245 \354\235\270\353\224\224\352\263\240 \353\260\244\355\225\230\353\212\230 \354\203\211\354\203\201 \354\234\204\354\227\220 \353\240\210\353\252\254 \354\230\220\353\241\234\354\232\260\354\231\200 \354\225\204\354\277\240\354\225\204 \354\212\244\354\271\264\354\235\264 \353\270\224\353\243\250\352\260\200 \354\235\200\354\235\200\355\225\230\352\262\214 \353\217\204\353\223\234\353\235\274\354\240\270 \353\247\210\354\235\214\354\235\204 \354\247\221\354\244\221\355\225\230\352\262\214 \353\247\214\353\223\255\353\213\210\353\213\244.\","
