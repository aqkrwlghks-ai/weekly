    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState } from \"react\";\nimport { DEFAULT_BULLETIN_DATA, DESIGN_THEMES } from \"./presets\";\nimport { BulletinData, DesignTheme } from \"./types\";\nimport WorshipForm from \"./components/WorshipForm\";\nimport MobilePreview from \"./components/MobilePreview\";\nimport DesignGuideView from \"./components/DesignGuideView\";\nimport { \n  Heart, \n  Sparkles, \n  BookOpen, \n  Smile, \n  HelpCircle, \n  Info,\n  Compass,\n  ArrowRight,\n  ClipboardCopy\n} from \"lucide-react\";\n\nexport default function App() {\n  const [bulletinData, setBulletinData] = useState<BulletinData>(DEFAULT_BULLETIN_DATA);\n  const [activeTheme, setActiveTheme] = useState<DesignTheme>(DESIGN_THEMES[0]);\n  const [showWelcomeMsg, setShowWelcomeMsg] = useState(true);\n\n  // Quick reset to default templates\n  const handleResetData = () => {\n    if (window.confirm(\"\354\243\274\353\263\264 \355\216\270\354\247\221 \353\202\264\354\232\251\354\235\204 \354\233\220\353\263\270 \352\270\260\352\260\222\354\234\274\353\241\234 \353\246\254\354\205\213\355\225\230\354\213\234\352\262\240\354\212\265\353\213\210\352\271\214?\")) {\n      setBulletinData(DEFAULT_BULLETIN_DATA);\n    }\n  };\n\n  return (\n    <div className=\"min-h-screen bg-slate-50/50 flex flex-col font-sans\">\n      \n      {/* Top Main Navigation / Bar */}\n      <header className=\"bg-white border-b border-slate-100 px-5 py-4 shrink-0 shadow-xs\">\n        <div className=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4\">\n          <div className=\"flex items-center gap-3\">\n            <div className=\"w-10 h-10 rounded-xl bg-teal-600 flex items-center justify-center text-white text-xl shadow-md rotate-3 hover:rotate-0 transition-transform cursor-pointer\">\n              \342\233\252\357\270\217\n            </div>\n            <div>\n              <div className=\"flex items-center gap-1.5\">\n                <h1 className=\"text-lg font-bold text-slate-800 tracking-tight\">\352\260\220\354\204\261 \353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264 \354\236\221\354\204\261\352\270\260</h1>\n                <span className=\"text-[10px] font-bold bg-teal-50 text-teal-700 py-0.5 px-2 rounded-full border border-teal-100\">\n                  Z\354\204\270\353\214\200 \354\202\254\354\227\255 \354\227\220\353\224\224\355\204\260\n                </span>\n              </div>\n              <p className=\"text-xs text-slate-500\">\n                \355\206\240\354\232\224\354\235\274 \354\240\200\353\205\201, \354\232\260\353\246\254 \354\262\255\353\205\204\353\223\244\354\235\230 \353\251\224\354\213\240\354\240\200\354\227\220 \355\235\230\353\237\254\352\260\210 \353\213\244\354\240\225\355\225\230\352\263\240 \355\236\231\355\225\234 \354\243\274\354\235\274 \354\230\210\353\260\260 \353\252\250\353\260\224\354\235\274 \352\260\200\354\235\264\353\223\234\n              </p>\n            </div>\n          </div>\n\n          {/* Quick Info & Action Header */}\n          <div className=\"flex items-center gap-2.5\">\n            <button\n               onClick={handleResetData}\n               className=\"text-xs font-semibold text-slate-500 hover:text-slate-800 bg-slate-100 hover:bg-slate-200 border border-slate-200 py-2 px-3 rounded-xl transition-all\"\n               id=\"reset-bulletin-btn\"\n            >\n              \354\264\210\352\270\260\352\260\222 \353\246\254\354\205\213\n            </button>\n            <div className=\"text-right hidden md:block\">\n              <span className=\"text-[10px] text-slate-400 font-mono block\">\354\230\244\353\212\230\354\235\230 \354\202\254\354\227\255 \354\272\230\353\246\260\353\215\224</span>\n              <span className=\"text-xs font-bold text-slate-600\">\353\202\264\354\235\274\354\235\200 \352\261\260\353\243\251\355\225\234 \354\243\274\354\235\274 \354\230\210\353\260\260 \360\237\214\277</span>\n            </div>\n          </div>\n        </div>\n      </header>\n\n      {/* Main Workspace Container */}\n      <main className=\"flex-1 max-w-7xl w-full mx-auto p-4 md:p-6 flex flex-col gap-5\">\n        \n        {/* Welcome Pastor Message Roleplay Callout */}\n        {showWelcomeMsg && (\n          <div \n            className=\"bg-teal-50/60 border border-teal-100/60 rounded-2xl p-4 flex gap-3.5 relative transition-all duration-300 animate-fade-in\"\n            id=\"welcome-pastors-box\"\n          >\n            <div className=\"w-12 h-12 rounded-full bg-teal-100 text-teal-700 flex items-center justify-center shrink-0 shadow-inner text-xl\">\n              \360\237\225\212\357\270\217\n            </div>\n            <div className=\"text-xs text-teal-900 leading-relaxed max-w-5xl pr-6\">\n              <div className=\"flex items-center gap-1.5 mb-1 text-teal-800\">\n                <span className=\"font-bold\">\353\260\230\352\260\200\354\233\214\354\232\224! \354\262\255\354\206\214\353\205\204/\354\262\255\353\205\204\353\266\200\353\245\274 \354\247\200\352\267\271\355\236\210 \355\222\210\352\263\240 \354\204\254\352\270\260\353\212\224 \353\202\255\353\247\214 \354\202\254\354\227\255\354\236\220\353\213\230! \360\237\214\277</span>\n                <span className=\"text-[10px] bg-teal-600 text-white px-2 py-0.5 rounded-full font-mono\">Pastor Chat</span>\n              </div>\n              <p className=\"opacity-90\">\n                \353\202\264\354\235\274 \354\243\274\354\235\274 \354\230\210\353\260\260\353\245\274 \354\225\236\353\221\224 \355\206\240\354\232\224\354\235\274 \354\240\200\353\205\201, \354\232\260\353\246\254 \354\247\200\354\262\264\353\223\244\354\235\230 \355\224\274\353\241\234\355\225\234 \354\235\274\354\203\201\354\227\220 \353\224\260\353\234\273\355\225\234 \353\205\270\355\201\254\352\260\200 \353\220\230\354\226\264 \354\244\204 \352\260\220\352\260\201\354\240\201\354\235\270 1\354\252\275 \353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264 \354\240\204\354\206\241\352\270\260\353\245\274 \354\204\240\353\254\274\355\225\264 \353\223\234\353\240\244\354\232\224. \n                \353\204\210\353\254\264 \353\224\261\353\224\261\355\225\230\352\263\240 \353\254\264\352\261\260\354\232\264 \354\242\205\352\265\220\354\240\201\354\235\270 \354\226\264\353\262\225\354\235\200 \354\244\204\354\235\264\352\263\240, \353\247\210\354\271\230 \353\213\244\354\240\225\355\225\234 \355\230\225/\353\210\204\353\202\230 \355\230\271\354\235\200 \352\260\220\354\204\261 \352\260\200\353\223\235\355\225\234 \353\213\264\354\236\204 \354\202\254\354\202\254\352\260\200 \354\271\234\352\267\274\355\225\230\352\262\214 \353\247\220\354\235\204 \352\261\264\353\204\244\353\223\257 \352\260\200\354\203\201\354\235\230 \354\235\270\354\202\254\354\231\200 \354\235\274\354\240\225\354\235\204 \352\265\254\354\204\261\355\226\210\354\212\265\353\213\210\353\213\244.\n                \354\225\204\353\236\230 <strong>[1. \355\205\214\353\247\210 \354\204\240\355\203\235]</strong>\354\235\204 \355\206\265\355\225\264 \354\240\212\354\235\200 \354\270\265\354\235\264 \354\227\264\352\264\221\355\225\240 \353\224\224\354\236\220\354\235\270 \355\206\244\354\235\204 \352\263\240\353\245\264\352\263\240, \354\231\274\354\252\275 \355\214\250\353\204\220\354\227\220\354\204\234 \354\243\274\353\263\264 \354\240\225\353\263\264\353\245\274 \354\236\205\353\240\245\355\225\264 \353\263\264\354\204\270\354\232\224. \354\271\264\355\206\241 \353\263\265\354\202\254\353\277\220\353\247\214 \354\225\204\353\213\210\353\235\274 <strong>\353\257\270\353\246\254\354\272\224\353\262\204\354\212\244/Canva \354\236\221\354\227\205\354\232\251 \354\240\204\354\232\251 \353\224\224\354\236\220\354\235\270 \355\214\201\352\263\274 \354\212\244\354\231\200\354\271\230</strong>\353\217\204 \355\225\250\352\273\230 \354\225\210\353\202\264\353\220\251\353\213\210\353\213\244.\n              </p>\n            </div>\n            <button\n              onClick={() => setShowWelcomeMsg(false)}\n              className=\"absolute top-3 right-3 text-teal-400 hover:text-teal-700 text-sm font-bold w-6 h-6 flex items-center justify-center rounded-full hover:bg-teal-100/40 transition-all focus:outline-none\"\n              title=\"\354\225\210\353\202\264 \353\213\253\352\270\260\"\n              id=\"close-welcome-btn\"\n            >\n              \303\227\n            </button>\n          </div>\n        )}\n\n        {/* Section: Interactive Theme Picker */}\n        <div className=\"bg-white rounded-2xl border border-slate-100 shadow-xs p-5\" id=\"theme-selector-root\">\n          <div className=\"flex items-center gap-2 mb-3.5\">\n            <Compass className=\"w-5 h-5 text-teal-600\" />\n            <h2 className=\"text-sm font-bold text-slate-800 tracking-tight\">\n              [1\353\213\250\352\263\204] \353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264 \353\224\224\354\236\220\354\235\270 \352\260\220\354\204\261 \355\206\244\354\225\244\353\247\244\353\204\210 \354\204\240\355\203\235\n            </h2>\n            <span className=\"text-[10px] text-slate-400\">\354\204\240\355\203\235\355\225\234 \352\260\220\354\204\261\354\235\264 \354\213\244\354\213\234\352\260\204 \353\252\250\353\260\224\354\235\274 \355\217\260 \353\240\214\353\215\224\353\247\201\354\227\220 \354\230\201\354\236\205\353\220\251\353\213\210\353\213\244!</span>\n          </div>\n\n          <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3\">\n            {DESIGN_THEMES.map((theme) => {\n              const isActive = activeTheme.id === theme.id;\n              return (\n                <button\n                  key={theme.id}\n                  onClick={() => setActiveTheme(theme)}\n                  className={`p-4 rounded-xl text-left border transition-all flex flex-col gap-1.5 focus:outline-none select-none relative overflow-hidden ${\n                    isActive\n                      ? \"border-teal-500 bg-teal-500/5 ring-1 ring-teal-500/20 shadow-md\"\n                      : \"border-slate-200 bg-white hover:bg-slate-50 hover:border-slate-350\"\n                  }`}\n                  id={`theme-btn-${theme.id}`}\n                >\n                  {isActive && (\n                    <div className=\"absolute top-0 right-0 bg-teal-600 text-white p-1 rounded-bl-lg text-[9px] font-bold\">\n                      \354\204\240\355\203\235\353\220\250\n                    </div>\n                  )}\n                  <div className=\"flex items-center gap-2\">\n                    {/* Visual Color Dots snippet */}\n                    <div className=\"flex gap-1\">\n                      {theme.colors.slice(0, 3).map((col, idx) => (\n                        <span key={idx} className={`w-3 h-3 rounded-full ${col.tailwind} border border-black/5`}></span>\n                      ))}\n                    </div>\n                    <span className=\"text-xs font-extrabold text-slate-800\">\n                      {theme.name}\n                    </span>\n                  </div>\n                  <p className=\"text-[11px] text-slate-500 leading-normal\">\n                    {theme.description}\n                  </p>\n                  <span className=\"text-[10px] font-mono text-teal-600 bg-teal-50 py-0.5 px-2 rounded-full self-start font-semibold\">\n                    {theme.fontNameKorean}\n                  </span>\n                </button>\n              );\n            })}\n          </div>\n        </div>\n\n        {/* Section: Three Column Custom Workspace */}\n        <div className=\"grid grid-cols-1 md:grid-cols-12 gap-6 items-start\" id=\"three-column-grid\">\n          \n          {/* Column A: Information Builder Form (Left Panel) */}\n          <div className=\"col-span-12 lg:col-span-4 flex flex-col gap-3\">\n            <div className=\"flex items-center gap-1 px-1 text-slate-500 text-xs font-bold uppercase tracking-widest shrink-0\">\n              <span className=\"bg-slate-400 text-white rounded-full w-4.5 h-4.5 flex items-center justify-center text-[9px] mr-1\">A</span>\n              <span>\353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264 \354\240\225\353\263\264 \353\224\224\355\205\214\354\235\274 \355\216\270\354\247\221\352\270\260</span>\n            </div>\n            <WorshipForm \n              data={bulletinData} \n              onChange={setBulletinData} \n            />\n          </div>\n\n          {/* Column B: Interactive Smartphone Mockup (Center Panel) */}\n          <div className=\"col-span-12 md:col-span-6 lg:col-span-4 flex flex-col gap-3 items-center\">\n            <div className=\"w-full flex items-center gap-1 px-1 text-slate-500 text-xs font-bold uppercase tracking-widest shrink-0\">\n              <span className=\"bg-slate-400 text-white rounded-full w-4.5 h-4.5 flex items-center justify-center text-[9px] mr-1\">B</span>\n              <span>1\354\252\275 \353\252\250\353\260\224\354\235\274 \354\271\264\353\223\234 & \354\240\204\354\206\241 \354\213\244\354\213\234\352\260\204 \353\257\270\353\246\254\353\263\264\352\270\260</span>\n            </div>\n            <MobilePreview \n              data={bulletinData} \n              activeTheme={activeTheme} \n            />\n          </div>\n\n          {/* Column C: Canva/Miricanvas Production Guide (Right Panel) */}\n          <div className=\"col-span-12 md:col-span-6 lg:col-span-4 flex flex-col gap-3\">\n            <div className=\"flex items-center gap-1 px-1 text-slate-500 text-xs font-bold uppercase tracking-widest shrink-0\">\n              <span className=\"bg-slate-400 text-white rounded-full w-4.5 h-4.5 flex items-center justify-center text-[9px] mr-1\">C</span>\n              <span>\353\257\270\353\246\254\354\272\224\353\262\204\354\212\244 & Canva \353\224\224\354\236\220\354\235\270 \354\240\204\354\210\240 \352\260\200\354\235\264\353\223\234</span>\n            </div>\n            <DesignGuideView \n              activeTheme={activeTheme} \n            />\n          </div>\n\n        </div>\n\n      </main>\n\n      {/* App Main Bottom Banner */}\n      <footer className=\"bg-slate-900 text-slate-400 py-6 px-5 mt-auto text-center border-t border-slate-800 text-xs\">\n        <div className=\"max-w-7xl mx-auto space-y-2\">\n          <p className=\"font-semibold text-slate-300 flex items-center justify-center gap-1\">\n            <span>\342\233\252\357\270\217</span> \354\230\210\353\260\260\354\231\200 \352\263\265\353\217\231\354\262\264\353\245\274 \352\271\212\354\235\264 \354\202\254\353\252\250\355\225\230\353\212\224 \353\223\240\353\223\240\355\225\234 \354\262\255\353\205\204 \353\217\231\354\227\255\354\236\220\353\223\244\352\263\274 \355\225\250\352\273\230\355\225\251\353\213\210\353\213\244.\n          </p>\n          <p className=\"text-slate-500 max-w-xl mx-auto leading-relaxed text-[11px]\">\n            \354\236\221\354\204\261\352\270\260\354\227\220\354\204\234 \354\240\234\352\263\265\355\225\230\353\212\224 \355\205\215\354\212\244\355\212\270 \354\205\260\354\226\264\353\247\201 \355\214\214\354\235\274\354\235\200 \352\260\234\354\235\270\354\240\225\353\263\264\353\245\274 \353\263\264\355\230\270\355\225\230\353\251\260, \355\201\264\353\235\274\354\235\264\354\226\270\355\212\270 \353\270\214\353\235\274\354\232\260\354\240\200 \353\241\234\354\273\254 \354\240\200\354\236\245\354\234\274\353\241\234 \353\251\224\353\252\250\353\246\254\353\245\274 \353\210\204\354\210\230\355\225\230\354\247\200 \354\225\212\354\212\265\353\213\210\353\213\244. \353\202\264\354\235\274 \354\236\210\354\235\204 \354\262\255\354\206\214\353\205\204/\354\262\255\353\205\204\353\223\244\354\235\230 \354\230\210\353\260\260\352\260\200 \354\203\235\353\252\205\353\240\245 \354\236\210\352\270\260\353\245\274 \352\260\204\354\240\210\355\236\210 \354\266\225\353\263\265\355\225\251\353\213\210\353\213\244.\n          </p>\n          <div className=\"pt-2 text-[10px] text-slate-600 block\">\n             \302\251 2026 Mobile Bulletin Editor for Generational Ministry. Made with Pure Craft.\n          </div>\n        </div>\n      </footer>\n\n    </div>\n  );\n}\n"
