        lines {
          text: "      content: \"\354\235\264\353\262\210 \354\243\274 \354\206\214\352\267\270\353\243\271 \354\225\274\354\231\270 \353\264\204 \354\206\214\355\222\215 \355\235\254\353\247\235 \353\266\200\354\247\200 \355\210\254\355\221\234\352\260\200 \354\230\244\353\212\230 \354\236\220\354\240\225 \353\247\210\352\260\220\353\220\251\353\213\210\353\213\244! \353\214\200\353\214\223\352\270\200\354\235\264\353\202\230 \353\213\250\354\262\264 \355\206\241\353\260\251 \352\263\265\354\247\200 \354\203\201\353\213\250 \355\224\204\353\241\234\355\225\204 \353\247\201\355\201\254\353\245\274 \355\206\265\355\225\264 \354\206\214\354\244\221\355\225\234 \355\225\234 \355\221\234 \355\226\211\354\202\254\355\225\264 \354\243\274\354\204\270\354\232\224!\","
