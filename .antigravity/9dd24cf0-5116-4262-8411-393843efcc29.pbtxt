        lines {
          text: "    title: \"\355\225\234 \354\243\274 \353\217\231\354\225\210 \352\263\240\354\203\235 \353\247\216\354\225\230\354\226\264, \354\232\260\353\246\254 \353\202\264\354\235\274 \353\247\214\353\202\230\354\236\220! \360\237\221\213\","
