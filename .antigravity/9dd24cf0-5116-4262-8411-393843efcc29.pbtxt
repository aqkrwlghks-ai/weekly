        replacement_content: "            <div \n              style={{ \n                fontFamily: activeTheme.fontFamily.startsWith(\"font-[\")\n                  ? activeTheme.fontFamily.replace(\"font-[\", \"\").replace(\"]\", \"\").replace(/_/g, \" \")\n                  : activeTheme.fontFamily === \"font-playfair\"\n                    ? \"\'Playfair Display\', serif\"\n                    : undefined\n              }}\n              className={`flex-1 overflow-y-auto ${activeTheme.bgColor} ${activeTheme.textColor} p-5 pb-12 flex flex-col gap-6 relative select-none scrollbar-thin`}\n              id=\"card-mode-view\"\n            >"
