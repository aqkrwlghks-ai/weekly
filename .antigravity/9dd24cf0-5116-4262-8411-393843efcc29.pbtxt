    replacement_chunks {
      replacement_content: "import { BulletinData, DesignTheme } from \"./types\";\n\nexport const GREETING_PRESETS = [\n  {\n    id: \"g1\",\n    title: \"\355\225\234 \354\243\274 \353\217\231\354\225\210 \352\263\240\354\203\235 \353\247\216\354\225\230\354\226\264, \354\232\260\353\246\254 \353\202\264\354\235\274 \353\247\214\353\202\230\354\236\220! \360\237\221\213\",\n    content: \"\354\210\250\352\260\200\354\201\230\352\262\214 \353\213\254\353\240\244\354\230\250 \355\225\234 \354\243\274\354\235\230 \355\206\240\354\232\224\354\235\274 \354\240\200\353\205\201. \354\204\270\354\203\201\354\235\230 \354\206\214\354\235\214\354\235\200 \354\236\240\354\213\234 \352\272\274\353\221\224 \354\261\204, \354\236\210\353\212\224 \353\252\250\354\212\265 \352\267\270\353\214\200\353\241\234 \353\202\230\354\231\200\354\204\234 \355\216\270\355\236\210 \354\211\254\354\226\264\352\260\224\354\234\274\353\251\264 \354\242\213\352\262\240\354\226\264. \353\202\264\354\235\274 \354\230\210\353\260\260\355\225\230\353\212\224 \354\235\264\352\263\263\354\235\264 \353\204\210\354\235\230 \353\224\260\353\234\273\355\225\234 \354\211\274\355\221\234\354\235\264\352\270\260\353\245\274. \342\230\225\357\270\217\"\n  },\n  {\n    id: \"g2\",\n    title: \"\354\230\250\354\240\204\355\236\210 \353\204\210\353\245\274 \354\202\254\353\236\221\355\225\230\352\263\240 \352\270\260\354\201\250\354\234\274\353\241\234 \352\270\260\353\213\244\353\240\244 \342\234\250\",\n    content: \"\353\210\204\352\265\254\354\227\220\352\262\214\353\217\204 \355\204\270\354\226\264\353\206\223\354\247\200 \353\252\273\355\225\234 \353\247\210\354\235\214\354\235\230 \354\247\220\354\235\264 \354\236\210\353\213\244\353\251\264 \353\202\264\354\235\274 \354\240\204\353\266\200 \354\230\210\353\260\260 \353\223\234\353\246\254\353\212\224 \352\260\200\354\232\264\353\215\260 \354\217\237\354\225\204\353\206\223\352\270\270 \353\260\224\353\236\204\352\262\214. \354\243\274\353\213\230\354\235\200 \354\226\270\354\240\234\353\202\230 \353\204\210\354\235\230 \354\236\221\354\235\200 \354\213\240\354\235\214\354\227\220\353\217\204 \352\267\200 \352\270\260\354\232\270\354\235\264\354\213\234\353\213\210\352\271\214. \354\204\244\353\240\210\353\212\224 \353\247\230\354\234\274\353\241\234 \353\204\210\353\245\274 \352\270\260\353\213\244\353\240\244. \360\237\225\212\357\270\217\"\n  },\n  {\n    id: \"g3\",\n    title: \"\352\270\260\353\214\200\355\225\230\353\212\224 \354\243\274\354\235\274, \354\235\200\355\230\234\354\235\230 \355\214\214\353\217\204 \354\206\215\354\234\274\353\241\234! \360\237\214\212\",\n    content: \"\353\202\264\354\235\274 \354\232\260\353\246\254\354\235\230 \354\230\201\355\230\274\354\235\204 \354\235\200\355\230\234\353\241\234 \352\260\200\353\223\235 \354\261\204\354\232\270 \354\230\210\353\260\260\352\260\200 \354\244\200\353\271\204\353\220\230\354\226\264 \354\236\210\354\226\264. \354\232\260\353\246\254\352\260\200 \353\234\250\352\262\201\352\262\214 \354\260\254\354\226\221\355\225\240 \353\225\214 \354\236\204\355\225\230\354\213\244 \355\225\230\353\212\230\354\235\230 \354\261\204\354\232\260\354\213\254\354\235\204 \352\270\260\353\214\200\355\225\264\353\263\264\354\236\220. \352\270\260\354\201\234 \353\247\210\354\235\214\352\263\274 \352\261\264\352\260\225\355\225\234 \353\257\270\354\206\214\353\241\234 \353\202\264\354\235\274 \353\260\230\352\260\221\352\262\214 \354\235\270\354\202\254\355\225\230\354\236\220!\"\n  }\n];\n\nexport const DEFAULT_BULLETIN_DATA: BulletinData = {\n  greetingTitle: \"\355\225\234 \354\243\274 \353\217\231\354\225\210 \352\263\240\354\203\235 \353\247\216\354\225\230\354\226\264, \354\232\260\353\246\254 \353\202\264\354\235\274 \353\247\214\353\202\230\354\236\220! \360\237\221\213\",\n  greetingContent: \"\354\210\250\352\260\200\354\201\230\352\262\214 \353\213\254\353\240\244\354\230\250 \355\225\234 \354\243\274\354\235\230 \355\206\240\354\232\224\354\235\274 \354\240\200\353\205\201. \354\204\270\354\203\201\354\235\230 \354\206\214\354\235\214\354\235\200 \354\236\240\354\213\234 \352\272\274\353\221\224 \354\261\204, \354\236\210\353\212\224 \353\252\250\354\212\265 \352\267\270\353\214\200\353\241\234 \353\202\230\354\231\200\354\204\234 \355\216\270\355\236\210 \354\211\254\354\226\264\352\260\224\354\234\274\353\251\264 \354\242\213\352\262\240\354\226\264. \353\202\264\354\235\274 \354\230\210\353\260\260\355\225\230\353\212\224 \354\235\264\352\263\263\354\235\264 \353\204\210\354\235\230 \353\224\260\353\234\273\355\225\234 \354\211\274\355\221\234\354\235\264\352\270\260\353\245\274. \342\230\225\357\270\217\",\n  praiseSongs: [\n    \"\354\233\220\355\225\230\352\263\240 \353\260\224\353\235\274\352\263\240 \352\270\260\353\217\204\355\225\251\353\213\210\353\213\244 (My Desire, Hope and Prayer)\",\n    \"\353\202\264 \353\247\210\354\235\214\354\235\204 \352\260\200\353\223\235 \354\261\204\354\232\264 (Here I Am to Worship)\",\n    \"\352\275\203\353\223\244\353\217\204 (Flowers Everywhere)\"\n  ],\n  prayerLeader: \"\353\260\225\354\247\200\353\257\274 \354\236\204\354\233\220 (\354\262\255\353\205\204\353\266\200 \355\232\214\354\236\245)\",\n  bibleVerse: \"\353\241\234\353\247\210\354\204\234 12\354\236\245 1-2\354\240\210 (Romans 12:1-2)\",\n  sermonTitle: \"\353\202\230\353\245\274 \353\263\200\355\231\224\354\213\234\355\202\244\353\212\224 \352\260\200\354\236\245 \354\204\240\355\225\230\352\263\240 \354\230\250\354\240\204\355\225\234 \354\203\235\352\260\201\",\n  preacher: \"\354\235\264\352\262\275\353\257\274 \353\213\264\353\213\271 \354\240\204\353\217\204\354\202\254\353\213\230\",\n  decisionText: \"\353\247\220\354\224\200\354\227\220 \353\202\264 \354\202\266\354\235\204 \352\261\260\354\232\270\354\202\274\354\225\204, \353\202\230\354\235\230 \355\217\211\353\262\224\355\225\234 \354\235\274\354\203\201\354\235\204 \354\230\210\353\260\260\353\241\234 \353\260\224\352\276\270\354\226\264 \352\260\200\352\270\260\",\n  announcements: [\n    {\n      id: \"ann1\",\n      title: \"\354\227\254\353\246\204 \354\210\230\353\240\250\355\232\214 \354\204\240\353\223\261\353\241\235 \355\225\240\354\235\270 \353\247\210\352\260\220 \342\230\200\357\270\217\",\n      content: \"\354\235\264\353\262\210 \354\243\274 \354\243\274\354\235\274\352\271\214\354\247\200 1\354\260\250 \354\204\240\353\223\261\353\241\235 \353\260\217 \355\232\214\353\271\204 \355\225\240\354\235\270\354\235\264 \353\247\210\352\260\220\353\220\251\353\213\210\353\213\244! \355\224\204\353\241\234\355\225\204 \354\203\201\353\213\250 \353\247\201\355\201\254 \355\230\271\354\235\200 \352\265\254\352\270\200 \355\217\274\354\235\204 \355\206\265\355\225\264 \353\271\240\353\245\264\352\262\214 \354\213\240\354\262\255\355\225\230\354\204\270\354\232\224! \353\247\235\354\204\244\354\235\264\352\270\260\354\227\224 \354\235\200\355\230\234\352\260\200 \353\204\210\353\254\264 \355\201\254\353\213\265\353\213\210\353\213\244.\",\n      tag: \"#\354\227\254\353\246\204\354\210\230\353\240\250\355\232\214 #RE_CONNECT\"\n    },\n    {\n      id: \"ann2\",\n      title: \"\354\203\210\352\260\200\354\241\261 \355\231\230\354\230\201 \'\354\233\260\354\273\264 \355\205\214\354\235\264\353\270\224\' \360\237\215\260\",\n      content: \"\354\230\210\353\260\260 \355\233\204\354\227\220 \354\262\230\354\235\214 \354\230\250 \354\247\200\354\262\264\353\223\244\354\235\204 \354\234\204\355\225\234 \353\213\254\354\275\244\355\225\234 \355\231\230\354\230\201 \354\236\220\353\246\254\352\260\200 \353\247\210\353\240\250\353\220\230\354\226\264 \354\236\210\354\212\265\353\213\210\353\213\244. \353\266\200\353\213\264 \354\227\206\354\235\264 \354\230\210\353\260\260 \353\241\234\353\271\204 \354\275\224\354\235\264\353\205\270\353\213\210\354\225\204 \353\243\270\354\234\274\353\241\234 \354\230\244\354\205\224\354\204\234 \353\247\233\354\236\210\353\212\224 \353\247\210\354\271\264\353\241\261\352\263\274 \354\273\244\355\224\274 \355\225\250\352\273\230 \353\202\230\353\210\240\354\232\224!\",\n      tag: \"#\354\233\260\354\273\264\355\205\214\354\235\264\353\270\224 #\354\202\254\353\236\221\355\225\264\354\266\225\353\263\265\355\225\264\"\n    },\n    {\n      id: \"ann3\",\n      title: \"\352\270\260\353\266\200\354\231\200 \354\202\254\353\236\221\354\235\230 \'\354\230\267\354\236\245 \353\202\230\353\210\224\' \355\224\204\353\241\234\354\240\235\355\212\270 \360\237\221\225\",\n      content: \"\354\225\210 \354\236\205\353\212\224 \352\271\250\353\201\227\355\225\234 \354\230\267\354\235\204 \353\252\250\354\225\204 \354\247\200\354\227\255 \353\213\250\354\262\264\354\227\220 \352\270\260\353\266\200\355\225\230\353\212\224 \355\224\204\353\241\234\354\240\235\355\212\270\352\260\200 \353\213\244\354\235\214 \354\243\274\353\266\200\355\204\260 \354\247\204\355\226\211\353\220\251\353\213\210\353\213\244. \353\263\264\352\264\200 \354\203\201\355\203\234\352\260\200 \354\242\213\354\235\200 \354\225\204\354\232\260\355\204\260 \353\230\220\353\212\224 \354\205\224\354\270\240 \354\234\204\354\243\274\353\241\234 \353\252\250\354\225\204\354\243\274\354\204\270\354\232\224!\",\n      tag: \"#\354\202\254\353\236\221\353\202\230\353\210\224 #\353\224\260\353\234\273\355\225\234\353\202\230\353\210\224\"\n    }\n  ],\n  checklists: [\n    {\n      id: \"chk1\",\n      emoji: \"\342\217\260\",\n      text: \"\354\230\210\353\260\260 10\353\266\204 \354\240\204 \352\270\260\353\217\204\353\241\234 \354\244\200\353\271\204\355\225\230\352\270\260\",\n      subtext: \"\354\241\260\352\270\210 \354\235\274\354\260\215 \354\231\200\354\204\234 \354\212\244\353\247\210\355\212\270\355\217\260\354\235\200 \354\236\240\354\213\234 \354\247\204\353\217\231\354\234\274\353\241\234 \353\221\220\352\263\240, \354\241\260\354\232\251\355\225\234 \353\254\265\354\203\201\354\234\274\353\241\234 \354\235\200\355\230\234\354\235\230 \354\243\274\355\214\214\354\210\230\353\245\274 \353\247\236\354\266\224\354\226\264 \353\263\264\354\225\204\354\232\224.\"\n    },\n    {\n      id: \"chk2\",\n      emoji: \"\360\237\223\226\",\n      text: \"\354\204\261\352\262\275\354\261\205\352\263\274 \353\247\210\354\235\214\354\235\264 \353\213\264\352\270\264 \353\264\211\355\227\214 \354\244\200\353\271\204\",\n      subtext: \"\354\243\274\353\263\264\354\227\220 \354\240\201\355\236\214 \354\230\244\353\212\230\354\235\230 \353\247\220\354\224\200\354\235\204 \353\202\264 \354\206\220\354\234\274\353\241\234 \354\247\201\354\240\221 \354\260\276\352\263\240 \352\260\220\354\202\254\354\235\230 \353\247\210\354\235\214\354\235\204 \353\257\270\353\246\254 \354\240\220\352\262\200\355\225\264 \353\263\264\354\204\270\354\232\224.\"\n    },\n    {\n      id: \"chk3\",\n      emoji: \"\360\237\221\245\",\n      text: \"\354\204\234\353\241\234\354\227\220\352\262\214 \353\224\260\353\234\273\355\225\234 \353\210\210\354\235\270\354\202\254 \353\202\230\353\210\204\352\270\260\",\n      subtext: \"\354\262\230\354\235\214 \354\230\250 \354\247\200\354\262\264\353\202\230 \354\226\264\354\203\211\355\225\264\355\225\230\353\212\224 \353\210\210\353\271\233\354\235\264 \354\236\210\353\213\244\353\251\264 \353\250\274\354\240\200 \353\213\244\354\240\225\355\225\234 \354\225\210\353\266\200\354\231\200 \354\235\221\354\233\220\354\235\230 \354\235\270\354\202\254\353\245\274 \352\261\264\353\204\244\354\243\274\354\204\270\354\232\224.\"\n    }\n  ]\n};\n\nexport const INSTAGRAM_PRESETS = [\n  {\n    id: \"insta1\",\n    title: \"\352\263\265\353\217\231\354\262\264 \354\206\214\352\267\270\353\243\271 \354\210\234\353\252\250\354\236\204 \355\216\270\354\204\261 \360\237\214\277\",\n    content: \"2026\353\205\204 \355\225\230\353\260\230\352\270\260\353\245\274 \353\234\250\352\262\201\352\263\240 \355\226\211\353\263\265\355\225\230\352\262\214 \354\261\204\354\233\214\352\260\210 \354\203\210\353\241\234\354\232\264 \354\206\214\352\267\270\353\243\271(\354\210\234) \355\216\270\354\204\261\354\235\264 \354\231\204\353\243\214\353\220\230\354\227\210\354\212\265\353\213\210\353\213\244. \354\243\274\354\235\274 \352\264\221\352\263\240 \354\213\234\352\260\204\354\227\220 \353\260\234\355\221\234\353\220\230\353\213\210 \353\247\216\354\235\200 \352\270\260\353\214\200\354\231\200 \352\270\260\353\217\204 \353\266\200\355\203\201\353\223\234\353\246\275\353\213\210\353\213\244!\",\n    tag: \"#\354\203\210\353\241\234\354\232\264\354\210\234\353\252\250\354\236\204 #\355\225\250\352\273\230\352\261\270\354\226\264\352\260\200\352\270\260\"\n  },\n  {\n    id: \"insta2\",\n    title: \"\354\244\221\353\263\264\352\270\260\353\217\204 \354\271\264\353\223\234 \352\260\234\354\204\244 \360\237\231\217\",\n    content: \"\354\204\234\353\241\234 \353\247\210\354\235\214\354\235\230 \352\270\260\353\217\204\354\240\234\353\252\251\354\235\204 \353\202\230\353\210\214 \354\230\250\353\235\274\354\235\270 \352\261\264\354\235\230\352\260\200 \354\227\264\353\240\270\354\212\265\353\213\210\353\213\244. \354\235\265\353\252\205 \353\230\220\353\212\224 \352\270\260\353\252\205\354\234\274\353\241\234 \354\240\234\354\266\234\355\225\264\354\243\274\354\213\234\353\251\264 \354\236\204\354\233\220\353\213\250\352\263\274 \354\202\254\354\227\255\354\236\220\352\260\200 \353\247\244\354\235\274\354\235\204 \352\270\260\353\217\204\353\241\234 \353\223\240\353\223\240\355\236\210 \354\247\200\354\233\220\355\225\230\352\262\240\354\212\265\353\213\210\353\213\244.\",\n    tag: \"#\354\244\221\353\263\264\352\270\260\353\217\204 #\352\270\260\353\217\204\354\235\230\353\201\210\"\n  }\n];\n\nexport const DESIGN_THEMES: DesignTheme[] = [\n  {\n    id: \"theme-warm-cozy\",\n    name: \"\354\233\234 \354\275\224\354\247\200 \353\262\240\354\235\264\354\247\200 (Cafe Beige)\",\n    description: \"\353\224\260\353\234\273\355\225\234 \354\271\264\355\216\230\353\202\230 \354\235\274\354\203\201\354\235\230 \354\225\210\353\235\275\355\225\250\354\235\264 \353\212\220\352\273\264\354\247\200\353\212\224 \355\201\254\353\246\274\355\224\274\354\271\230 \354\227\220\353\224\224\354\205\230\",\n    concept: \"\353\247\210\354\235\214\354\235\230 \354\230\250\353\217\204\353\245\274 \353\206\222\354\227\254\354\243\274\353\212\224 \354\230\250\355\231\224\355\225\230\352\263\240 \353\213\250\354\225\204\355\225\234 \353\266\204\354\234\204\352\270\260. \353\210\210\354\235\264 \355\216\270\354\225\210\355\225\234 \355\216\230\354\235\264\355\215\274 \355\206\244 \353\262\240\352\262\275\354\227\220 \353\263\265\354\210\255\354\225\204\354\203\211 \355\217\254\354\235\270\355\212\270\353\245\274 \354\243\274\354\226\264 \354\204\270\354\213\254\355\225\230\352\263\240 \352\260\220\354\210\230\354\204\261\354\235\264 \355\222\215\353\266\200\355\225\234 \354\262\255\353\205\204\353\223\244\354\235\230 \352\260\220\354\204\261\354\227\220 \354\240\234\352\262\251\354\236\205\353\213\210\353\213\244.\",\n    bgColor: \"bg-amber-50/70\",\n    textColor: \"text-amber-950\",\n    accentBg: \"bg-amber-100\",\n    accentText: \"text-amber-800\",\n    cardBg: \"bg-white\",\n    borderColor: \"border-amber-100\",\n    fontFamily: \"font-[GowunBatang]\",\n    fontImportName: \"@import url(\'https://fonts.googleapis.com/css2?family=Gowun+Batang:wght@400;700&display=swap\');\",\n    fontNameKorean: \"\352\263\240\354\232\264\353\260\224\355\203\225 (Gowun Batang)\",\n    tagline: \"\353\224\260\354\212\244\355\225\230\352\263\240 \353\266\200\353\223\234\353\237\254\354\232\264 \354\225\204\353\202\240\353\241\234\352\267\270 \352\260\220\354\204\261 \352\260\200\353\223\235\",\n    colors: [\n      { name: \"\353\251\224\354\235\270 \355\201\254\353\246\274 \353\260\260\352\262\275\", hex: \"#FDFBF7\", tailwind: \"bg-[#FDFBF7]\", role: \"\354\247\200\353\251\264\354\240\201 \353\262\240\354\235\264\354\212\244 \353\260\217 \354\260\250\353\266\204\355\225\250 \354\234\240\354\247\200\" },\n      { name: \"\354\264\210\354\275\234\353\246\277 \352\263\204\354\227\264 \355\205\215\354\212\244\355\212\270\", hex: \"#451A03\", tailwind: \"bg-[#451A03]\", role: \"\355\216\270\354\225\210\355\225\234 \352\260\200\353\217\205\354\204\261\354\227\220 \352\271\212\354\235\264 \352\260\200\353\257\270\" },\n      { name: \"\353\224\260\354\212\244\355\225\234 \354\202\264\352\265\254 \355\217\254\354\235\270\355\212\270\", hex: \"#E07A5F\", tailwind: \"bg-[#E07A5F]\", role: \"\354\235\270\354\202\254\353\247\220 \352\260\225\354\241\260 \353\260\217 \354\243\274\354\232\224 \354\273\264\355\217\254\353\204\214\355\212\270 \355\233\204\352\264\221\" },\n      { name: \"\353\241\234\354\246\210\353\271\233 \353\262\240\354\235\264\354\247\200\", hex: \"#F2CC8F\", tailwind: \"bg-[#F2CC8F]\", role: \"\354\262\264\355\201\254\353\246\254\354\212\244\355\212\270 \354\236\245\354\213\235 \353\260\217 \354\225\204\354\235\264\354\275\230 \354\204\234\355\217\254\355\204\260\" }\n    ],\n    recommendedFonts: [\n      { target: \"\353\214\200\354\240\234\353\252\251 / \353\251\224\354\235\270 \355\203\200\354\235\264\355\213\200\", name: \"Gowun Batang (700 Bold)\", details: \"\354\225\204\353\246\204\353\213\265\352\263\240 \355\201\264\353\236\230\354\213\235\355\225\234 \352\260\220\354\204\261 \354\204\234\354\262\264. \354\240\225\354\204\261\354\212\244\353\237\275\352\262\214 \354\223\264 \355\216\270\354\247\200 \353\212\220\353\202\214 \354\260\275\354\266\234\" },\n      { target: \"\353\263\270\353\254\270 / \353\224\224\355\205\214\354\235\274 \353\246\254\354\212\244\355\212\270\", name: \"Pretendard \353\230\220\353\212\224 Gowun Batang\", details: \"\353\210\210\354\227\220 \352\261\260\354\212\244\353\246\204 \354\227\206\354\235\264 \354\240\225\352\260\210\355\225\230\352\262\214 \354\225\210\354\260\251\353\220\230\354\226\264 \355\216\270\354\225\210\355\225\230\352\262\214 \354\231\204\353\217\205 \352\260\200\353\212\245\355\225\234 \352\260\200\353\217\205\354\204\261 \353\263\264\354\236\245\" }\n    ]\n  },\n  {\n    id: \"theme-modern-mint\",\n    name: \"\354\213\234\355\201\254 \353\257\274\355\212\270 \354\212\254\353\240\210\354\235\264\355\212\270 (Modern Slate)\",\n    description: \"\354\235\270\354\212\244\355\203\200\352\267\270\353\236\250\354\235\264\353\202\230 \355\225\200\355\204\260\353\240\210\354\212\244\355\212\270\354\227\220\354\204\234 \353\247\216\354\235\264 \353\263\264\354\235\264\353\212\224 \354\277\250\355\225\230\352\263\240 \355\212\270\353\240\214\353\224\224\355\225\234 \353\254\264\353\223\234\",\n    concept: \"\354\204\270\353\240\250\353\220\230\352\263\240 \355\236\231\355\225\234 \353\240\210\354\235\264\354\225\204\354\233\203. \354\227\260\355\232\214\354\203\211 \353\254\264\354\261\204\354\203\211 \354\212\254\353\240\210\354\235\264\355\212\270 \353\262\240\354\235\264\354\212\244\354\227\220 \355\230\225\352\264\221\353\271\233\354\235\264 \352\260\220\353\217\204\353\212\224 \353\270\214\353\235\274\354\235\264\355\212\270 \353\257\274\355\212\270\352\267\270\353\246\260\354\235\204 \355\217\254\354\235\270\355\212\270\353\241\234 \354\202\274\354\225\204 \355\231\234\352\270\260\354\260\250\352\263\240 \354\240\225\352\260\210\355\225\234 \355\230\204\353\214\200 \354\204\270\353\214\200 \352\260\220\354\204\261\354\235\204 \354\236\220\352\267\271\355\225\251\353\213\210\353\213\244.\",\n    bgColor: \"bg-slate-50\",\n    textColor: \"text-slate-900\",\n    accentBg: \"bg-teal-100\",\n    accentText: \"text-teal-900\",\n    cardBg: \"bg-white\",\n    borderColor: \"border-slate-200\",\n    fontFamily: \"font-[Outfit]\",\n    fontImportName: \"@import url(\'https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&family=Noto+Sans+KR:wght@300;500;700&display=swap\');\",\n    fontNameKorean: \"\354\225\204\354\233\203\355\225\217 & \353\205\270\355\206\240\354\202\260\354\212\244 (Outfit & Noto Sans)\",\n    tagline: \"\352\265\260\353\215\224\353\215\224\352\270\260 \354\227\206\353\212\224 \353\217\204\355\232\214\354\240\201 \353\257\270\353\213\210\353\251\200\353\246\254\354\246\230\",\n    colors: [\n      { name: \"\354\230\244\355\224\204\355\231\224\354\235\264\355\212\270 \354\212\254\353\240\210\354\235\264\355\212\270\", hex: \"#F8FAFC\", tailwind: \"bg-[#F8FAFC]\", role: \"\354\240\225\352\260\210\355\225\250\352\263\274 \353\204\223\352\263\240 \352\271\250\353\201\227\355\225\234 \354\227\254\353\260\261 \352\260\200\354\235\264\353\223\234\" },\n      { name: \"\354\260\250\354\275\234 \353\270\224\353\236\231 \355\205\215\354\212\244\355\212\270\", hex: \"#0F172A\", tailwind: \"bg-[#0F172A]\", role: \"\355\231\225\354\213\244\355\225\230\352\263\240 \352\265\265\354\247\201\355\225\234 \354\240\234\353\252\251 \353\260\217 \352\262\275\352\263\204\352\260\220 \353\247\210\353\240\250\" },\n      { name: \"\355\214\235 \353\270\214\353\235\274\354\235\264\355\212\270 \353\257\274\355\212\270\", hex: \"#2DD4BF\", tailwind: \"bg-[#2DD4BF]\", role: \"\354\230\210\353\260\260 \354\210\234\354\204\234 \353\260\217 \354\235\270\354\212\244\355\203\200 \354\271\264\353\223\234 \354\243\274\354\232\224 \355\217\254\354\273\244\354\213\261 \353\262\250\355\212\270\" },\n      { name: \"\353\257\270\353\224\224\354\227\204 \352\267\270\353\240\210\354\235\264 \353\260\260\352\262\275\", hex: \"#E2E8F0\", tailwind: \"bg-[#E2E8F0]\", role: \"\353\266\200\353\223\234\353\237\254\354\232\264 \354\240\225\353\263\264 \352\265\254\353\266\204\354\235\204 \354\247\223\353\212\224 \353\263\264\355\226\211\354\204\240\" }\n    ],\n    recommendedFonts: [\n      { target: \"\353\214\200\354\240\234\353\252\251 / \354\230\201\353\254\270 \355\203\200\354\235\264\355\213\200\", name: \"Outfit (Extra Bold)\", details: \"\354\240\212\354\235\200 \354\204\270\353\214\200\353\223\244\354\235\230 \353\270\214\353\236\234\353\223\234\354\227\220 \354\236\220\354\243\274 \354\235\264\354\232\251\353\220\230\353\212\224 \354\204\270\353\240\250\353\220\234 \354\247\200\354\230\244\353\251\224\355\212\270\353\246\255 \355\217\260\355\212\270\" },\n      { target: \"\353\263\270\353\254\270 \355\225\234\352\270\200\", name: \"Noto Sans KR (Regular/Medium)\", details: \"\355\231\224\353\251\264 \353\260\200\353\217\204\353\245\274 \352\260\200\354\247\200\353\237\260\355\225\230\352\262\214 \354\261\204\354\233\214 \352\260\200\353\217\205\354\204\261\354\235\204 \354\265\234\352\263\240\354\271\230\353\241\234 \354\240\225\353\217\210\355\225\264 \354\243\274\353\212\224 \355\217\260\355\212\270\" }\n    ]\n  },\n  {\n    id: \"theme-deep-space\",\n    name: \"\353\224\245 \354\212\244\355\224\274\353\246\277 \353\202\230\354\236\207 (Deep Spiritual Space)\",\n    description: \"\353\260\244\355\225\230\353\212\230 \354\235\200\355\225\230\354\210\230 \353\260\221, \354\260\254\354\226\221 \354\202\254\354\227\255\352\263\274 \354\226\264\354\277\240\354\212\244\355\213\261 \354\230\210\353\260\260\354\227\220 \354\226\264\354\232\270\353\246\254\353\212\224 \352\260\220\354\204\261 \353\213\244\355\201\254 \353\252\250\353\223\234\",\n    concept: \"\354\230\244\354\247\201 \354\243\274\353\213\230\354\235\230 \354\236\204\354\236\254\354\231\200 \353\202\264 \353\202\264\353\251\264\354\235\230 \353\254\265\354\203\201\354\227\220 \352\263\240\353\217\204\353\241\234 \353\266\210\354\235\204 \353\260\235\355\236\210\353\212\224 \354\225\204\354\232\260\353\235\274 \353\254\264\353\223\234. \353\224\245 \354\235\270\353\224\224\352\263\240 \353\260\244\355\225\230\353\212\230 \354\203\211\354\203\201 \354\234\204\354\227\220 \353\240\210\353\252\254 \354\230\220\353\241\234\354\232\260\354\231\200 \354\225\204\354\277\240\354\225\204 \354\212\244\354\271\264\354\235\264 \353\270\224\353\243\250\352\260\200 \354\235\200\354\235\200\355\225\230\352\262\214 \353\217\204\353\223\234\353\235\274\354\240\270 \353\247\210\354\235\214\354\235\204 \354\247\221\354\244\221\355\225\230\352\262\214 \353\247\214\353\223\255\353\213\210\353\213\244.\",\n    bgColor: \"bg-slate-950\",\n    textColor: \"text-slate-100\",\n    accentBg: \"bg-slate-800\",\n    accentText: \"text-amber-300\",\n    cardBg: \"bg-slate-900/90\",\n    borderColor: \"border-slate-800\",\n    fontFamily: \"font-[SpaceGrotesk]\",\n    fontImportName: \"@import url(\'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=JetBrains+Mono:wght@400;500&display=swap\');\",\n    fontNameKorean: \"\354\212\244\355\216\230\354\235\264\354\212\244 \352\267\270\353\241\234\355\205\214\354\212\244\355\201\254 (Space Grotesk)\",\n    tagline: \"\354\226\264\354\212\244\353\246\204 \354\206\215\354\227\220\354\204\234 \353\271\233\353\202\230\353\212\224 \352\261\260\353\243\251\355\225\234 \354\212\244\355\216\231\355\212\270\353\237\274\",\n    colors: [\n      { name: \"\353\257\270\353\223\234\353\202\230\354\236\207 \354\235\270\353\224\224\352\263\240/\353\270\224\353\236\231\", hex: \"#020617\", tailwind: \"bg-[#020617]\", role: \"\353\217\204\354\213\254\354\235\230 \353\260\244\355\225\230\353\212\230, \352\263\240\354\232\224\355\225\234 \352\270\260\353\217\204\354\235\230 \353\213\244\353\235\275\353\260\251 \353\266\204\354\234\204\352\270\260\" },\n      { name: \"\354\206\214\355\224\204\355\212\270 \353\240\210\353\252\254 \354\230\220\353\241\234\", hex: \"#FEF08A\", tailwind: \"bg-[#FEF08A]\", role: \"\354\226\264\353\221\240 \354\206\215\354\227\220\354\204\234 \355\231\230\355\225\230\352\262\214 \354\274\234\354\247\200\353\212\224 \354\264\233\353\266\210\354\262\230\353\237\274 \354\244\221\354\232\224 \355\227\244\353\223\234\353\235\274\354\235\270 \354\236\245\354\213\235\" },\n      { name: \"\354\225\204\354\277\240\354\225\204 \353\235\274\354\235\264\355\212\270 \354\212\244\354\271\264\354\235\264\", hex: \"#38BDF8\", tailwind: \"bg-[#38BDF8]\", role: \"\354\260\254\354\226\221 \352\263\241\353\252\251 \353\260\217 \354\213\255\354\236\220\352\260\200 \354\213\254\353\263\274 \353\223\261 \354\234\240\354\232\251\355\225\234 \353\247\201\355\201\254 \353\240\210\354\235\264\354\226\264\353\247\201\" },\n      { name: \"\354\212\244\353\252\250\355\201\254 \354\213\244\353\262\204 \352\267\270\353\240\210\354\235\264\", hex: \"#94A3B8\", tailwind: \"bg-[#94A3B8]\", role: \"\353\263\270\353\254\270\354\235\230 \355\224\274\353\241\234\353\217\204\353\245\274 \353\210\204\353\245\264\352\263\240 \354\236\224\354\236\224\355\225\230\352\262\214 \353\205\271\354\235\204 \354\210\230 \354\236\210\353\217\204\353\241\235 \353\260\233\354\263\220\354\243\274\353\212\224 \354\204\234\354\262\264\353\245\274 \353\213\264\353\213\271\" }\n    ],\n    recommendedFonts: [\n      { target: \"\353\214\200\354\240\234\353\252\251 / \354\230\201\353\254\270 \354\212\254\353\241\234\352\261\264\", name: \"Space Grotesk (700)\", details: \"\355\205\214\355\201\254\353\213\210\354\273\254\355\225\230\353\251\264\354\204\234\353\217\204 \353\271\210\355\213\260\354\247\200\355\225\234 \353\251\213\354\235\264 \354\202\264\354\225\204\354\236\210\353\212\224 \355\217\260\355\212\270. \353\254\264\355\225\234\355\225\234 \355\225\230\353\212\230\354\235\204 \355\221\234\355\230\204\" },\n      { target: \"\353\224\224\355\205\214\354\235\274 \353\215\260\354\235\264\355\204\260 \353\260\217 \355\225\234\352\270\200\", name: \"JetBrains Mono / Pretendard\", details: \"\354\240\225\353\263\264\353\245\274 \352\271\224\353\201\224\355\225\230\352\263\240 \353\271\210\355\213\260\354\247\200\355\225\234 \354\225\204\353\240\210\353\202\230 \355\203\200\354\236\220\352\270\260 \354\212\244\355\203\200\354\235\274\353\241\234 \354\240\204\353\213\254\" }\n    ]\n  }\n];\n"
    }
