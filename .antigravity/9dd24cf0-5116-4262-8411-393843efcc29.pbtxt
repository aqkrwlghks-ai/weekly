        lines {
          text: "      content: \"\353\213\244\354\235\214 \354\243\274 \354\243\274\354\235\274 \354\230\210\353\260\260 \355\233\204 \354\271\234\352\265\220\354\213\244 \354\271\264\355\216\230 \'\354\230\250\'\354\227\220\354\204\234 \354\206\214\353\260\225\355\225\230\352\263\240 \352\260\220\352\260\201\354\240\201\354\235\270 \354\203\210 \354\247\200\354\262\264 \355\231\230\354\230\201 \353\213\244\352\263\274\355\232\214\352\260\200 \354\236\210\352\262\240\354\212\265\353\213\210\353\213\244. \353\252\250\353\223\240 \354\203\210\354\271\234\352\265\254\353\223\244\352\263\274 \352\270\260\354\241\264 \354\210\234\354\236\245\353\213\230\353\223\244\354\235\200 \352\274\255 \354\260\270\354\204\235\355\225\264 \354\243\274\354\204\270\354\232\224!\","
