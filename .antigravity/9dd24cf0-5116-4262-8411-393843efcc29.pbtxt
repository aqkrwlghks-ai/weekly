    user_response: "\353\204\210\353\212\224 \352\265\220\355\232\214 \354\262\255\354\206\214\353\205\204/\354\262\255\353\205\204\353\266\200\353\245\274 \354\204\254\352\270\260\353\212\224 \352\260\220\352\260\201\354\240\201\354\235\264\352\263\240 \353\224\260\353\234\273\355\225\234 \354\202\254\354\227\255\354\236\220\354\225\274. \353\202\264\354\235\274(\354\243\274\354\235\274) \354\230\210\353\260\260\353\245\274 \352\270\260\353\214\200\355\225\230\353\212\224 \353\247\210\354\235\214\354\235\204 \353\213\264\354\225\204, \353\266\200\354\204\234\354\233\220\353\223\244\354\227\220\352\262\214 \355\206\240\354\232\224\354\235\274 \354\240\200\353\205\201\354\227\220 \353\260\234\354\206\241\355\225\240 \'\353\213\250\354\236\245(1\355\216\230\354\235\264\354\247\200) \353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264\' \355\205\215\354\212\244\355\212\270\354\231\200 \353\224\224\354\236\220\354\235\270 \352\260\200\354\235\264\353\223\234\353\245\274 \354\236\221\354\204\261\355\225\264 \354\244\230.\n\n[\352\265\254\354\204\261 \354\232\224\354\206\214]\n1. \354\230\244\355\224\204\353\213\235 \354\235\270\354\202\254\353\247\220:\n- \354\262\255\354\206\214\353\205\204\352\263\274 \354\262\255\353\205\204\353\223\244\354\235\230 \352\260\220\354\204\261\354\227\220 \353\247\236\353\212\224 \355\212\270\353\240\214\353\224\224\355\225\230\352\263\240 \353\213\244\354\240\225\355\225\234 \354\243\274\353\247\220 \354\235\270\354\202\254. (\353\204\210\353\254\264 \354\230\254\353\223\234\355\225\234 \354\242\205\352\265\220\354\240\201 \355\221\234\355\230\204\354\235\200 \355\224\274\355\225\230\352\263\240 \354\271\234\352\267\274\355\225\230\352\262\214)\n\n2. \354\230\210\353\260\260\354\210\234\354\204\234:\n- \353\213\244\354\235\214 \354\210\234\354\204\234\353\245\274 \353\263\264\352\270\260 \354\242\213\352\263\240 \352\260\220\352\260\201\354\240\201\354\234\274\353\241\234 \353\202\230\354\227\264\355\225\264 \354\244\230:\n  \342\200\242 \360\237\216\265 \354\260\254\354\226\221 (\354\235\264\353\262\210 \354\243\274 \354\260\254\354\226\221: [\352\263\241\353\252\205 1], [\352\263\241\353\252\205 2], [\352\263\241\353\252\205 3])\n  \342\200\242 \360\237\231\217 \353\214\200\355\221\234\352\270\260\353\217\204 ([\353\213\264\353\213\271\354\236\220 \354\235\264\353\246\204])\n  \342\200\242 \360\237\223\242 \352\264\221\352\263\240\n  \342\200\242 \360\237\223\226 \353\247\220\354\224\200\353\264\211\353\217\205 ([\354\204\261\352\262\275 \352\265\254\354\240\210])\n  \342\200\242 \360\237\222\214 \353\264\211\355\227\214&\352\270\260\353\217\204\n  \342\200\242 \354\213\255 \353\247\220\354\224\200 ([\354\204\244\352\265\220 \354\240\234\353\252\251] - [\354\204\244\352\265\220\354\236\220])\n  \342\200\242 \360\237\224\245 \352\262\260\353\213\250\n\n3. \353\266\200\354\204\234 \352\264\221\352\263\240 (\354\206\214\354\213\235):\n- \354\235\264\353\262\210 \354\243\274 \354\247\204\355\226\211\353\220\230\353\212\224 \354\243\274\354\232\224 \354\235\274\354\240\225 \353\223\261 \352\260\200\354\203\201\354\235\230 \352\264\221\352\263\240 \354\202\254\355\225\255 2~3\352\260\200\354\247\200\353\245\274 \354\235\270\354\212\244\355\203\200\352\267\270\353\236\250 \355\224\274\353\223\234\353\202\230 \354\212\244\355\206\240\353\246\254 \353\212\220\353\202\214\354\234\274\353\241\234 \352\260\204\352\262\260\355\225\230\352\262\214 \354\236\221\354\204\261\355\225\264 \354\244\230. (\352\264\204\355\230\270\353\245\274 \354\263\220\354\204\234 \353\202\230\354\244\221\354\227\220 \354\210\230\354\240\225\355\225\230\352\270\260 \354\211\275\352\262\214)\n\n4. \354\230\210\353\260\260 \354\240\204 \354\240\220\352\262\200\354\202\254\355\225\255:\n- \354\230\210\353\260\260 10\353\266\204 \354\240\204 \353\217\204\354\260\251, \355\227\214\352\270\210/\354\204\261\352\262\275 \354\244\200\353\271\204, \352\270\260\353\217\204\353\241\234 \354\244\200\353\271\204\355\225\230\353\212\224 \353\247\210\354\235\214 \353\223\261 3\352\260\200\354\247\200 \354\262\264\355\201\254\353\246\254\354\212\244\355\212\270\353\245\274 \354\204\274\354\212\244 \354\236\210\353\212\224 \354\235\264\353\252\250\354\247\200\354\231\200 \355\225\250\352\273\230 \353\266\200\353\223\234\353\237\275\352\262\214 \352\266\214\353\251\264\355\225\264 \354\244\230.\n\n[\353\224\224\354\236\220\354\235\270 \352\260\200\354\235\264\353\223\234 & \354\266\234\353\240\245 \354\241\260\352\261\264]\n- \355\205\215\354\212\244\355\212\270 \354\240\204\354\262\264 \353\266\204\353\237\211\354\235\200 \354\212\244\353\247\210\355\212\270\355\217\260 \355\231\224\353\251\264 1\354\236\245\354\227\220 \354\227\254\353\260\261\354\235\204 \353\221\220\352\263\240 \353\223\244\354\226\264\352\260\210 \354\210\230 \354\236\210\353\217\204\353\241\235 \354\225\225\354\266\225\354\240\201\354\234\274\353\241\234 \354\236\221\354\204\261\355\225\240 \352\262\203.\n- \355\205\215\354\212\244\355\212\270 \354\266\234\353\240\245 \355\233\204 \355\225\230\353\213\250\354\227\220, \354\235\264 \353\202\264\354\232\251\354\235\204 \'\353\257\270\353\246\254\354\272\224\353\262\204\354\212\244\'\353\202\230 \'Canva(\354\272\224\353\260\224)\'\353\241\234 \354\240\234\354\236\221\355\225\240 \353\225\214 \354\262\255\354\206\214\353\205\204/\354\262\255\353\205\204\353\223\244\354\235\264 \354\242\213\354\225\204\355\225\240 \353\247\214\355\225\234 \354\225\204\353\236\230\354\235\230 \353\224\224\354\236\220\354\235\270 \355\214\201\354\235\204 \354\240\234\354\225\210\355\225\264 \354\244\230:\n  1) \354\240\204\354\262\264\354\240\201\354\235\270 \353\224\224\354\236\220\354\235\270 \353\254\264\353\223\234/\354\273\250\354\205\211 \354\240\234\354\225\210\n  2) \354\226\264\354\232\270\353\246\254\353\212\224 \355\212\270\353\240\214\353\224\224\355\225\234 \354\266\224\354\262\234 \355\217\260\355\212\270 (\354\240\234\353\252\251\354\232\251 / \353\263\270\353\254\270\354\232\251)\n  3) \354\266\224\354\262\234 \354\273\254\353\237\254 \355\214\224\353\240\210\355\212\270 (\353\251\224\354\235\270 \354\273\254\353\237\254 & \355\217\254\354\235\270\355\212\270 \354\273\254\353\237\254)\n"
    items {
      text: "\353\204\210\353\212\224 \352\265\220\355\232\214 \354\262\255\354\206\214\353\205\204/\354\262\255\353\205\204\353\266\200\353\245\274 \354\204\254\352\270\260\353\212\224 \352\260\220\352\260\201\354\240\201\354\235\264\352\263\240 \353\224\260\353\234\273\355\225\234 \354\202\254\354\227\255\354\236\220\354\225\274. \353\202\264\354\235\274(\354\243\274\354\235\274) \354\230\210\353\260\260\353\245\274 \352\270\260\353\214\200\355\225\230\353\212\224 \353\247\210\354\235\214\354\235\204 \353\213\264\354\225\204, \353\266\200\354\204\234\354\233\220\353\223\244\354\227\220\352\262\214 \355\206\240\354\232\224\354\235\274 \354\240\200\353\205\201\354\227\220 \353\260\234\354\206\241\355\225\240 \'\353\213\250\354\236\245(1\355\216\230\354\235\264\354\247\200) \353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264\' \355\205\215\354\212\244\355\212\270\354\231\200 \353\224\224\354\236\220\354\235\270 \352\260\200\354\235\264\353\223\234\353\245\274 \354\236\221\354\204\261\355\225\264 \354\244\230.\n\n[\352\265\254\354\204\261 \354\232\224\354\206\214]\n1. \354\230\244\355\224\204\353\213\235 \354\235\270\354\202\254\353\247\220:\n- \354\262\255\354\206\214\353\205\204\352\263\274 \354\262\255\353\205\204\353\223\244\354\235\230 \352\260\220\354\204\261\354\227\220 \353\247\236\353\212\224 \355\212\270\353\240\214\353\224\224\355\225\230\352\263\240 \353\213\244\354\240\225\355\225\234 \354\243\274\353\247\220 \354\235\270\354\202\254. (\353\204\210\353\254\264 \354\230\254\353\223\234\355\225\234 \354\242\205\352\265\220\354\240\201 \355\221\234\355\230\204\354\235\200 \355\224\274\355\225\230\352\263\240 \354\271\234\352\267\274\355\225\230\352\262\214)\n\n2. \354\230\210\353\260\260\354\210\234\354\204\234:\n- \353\213\244\354\235\214 \354\210\234\354\204\234\353\245\274 \353\263\264\352\270\260 \354\242\213\352\263\240 \352\260\220\352\260\201\354\240\201\354\234\274\353\241\234 \353\202\230\354\227\264\355\225\264 \354\244\230:\n  \342\200\242 \360\237\216\265 \354\260\254\354\226\221 (\354\235\264\353\262\210 \354\243\274 \354\260\254\354\226\221: [\352\263\241\353\252\205 1], [\352\263\241\353\252\205 2], [\352\263\241\353\252\205 3])\n  \342\200\242 \360\237\231\217 \353\214\200\355\221\234\352\270\260\353\217\204 ([\353\213\264\353\213\271\354\236\220 \354\235\264\353\246\204])\n  \342\200\242 \360\237\223\242 \352\264\221\352\263\240\n  \342\200\242 \360\237\223\226 \353\247\220\354\224\200\353\264\211\353\217\205 ([\354\204\261\352\262\275 \352\265\254\354\240\210])\n  \342\200\242 \360\237\222\214 \353\264\211\355\227\214&\352\270\260\353\217\204\n  \342\200\242 \354\213\255 \353\247\220\354\224\200 ([\354\204\244\352\265\220 \354\240\234\353\252\251] - [\354\204\244\352\265\220\354\236\220])\n  \342\200\242 \360\237\224\245 \352\262\260\353\213\250\n\n3. \353\266\200\354\204\234 \352\264\221\352\263\240 (\354\206\214\354\213\235):\n- \354\235\264\353\262\210 \354\243\274 \354\247\204\355\226\211\353\220\230\353\212\224 \354\243\274\354\232\224 \354\235\274\354\240\225 \353\223\261 \352\260\200\354\203\201\354\235\230 \352\264\221\352\263\240 \354\202\254\355\225\255 2~3\352\260\200\354\247\200\353\245\274 \354\235\270\354\212\244\355\203\200\352\267\270\353\236\250 \355\224\274\353\223\234\353\202\230 \354\212\244\355\206\240\353\246\254 \353\212\220\353\202\214\354\234\274\353\241\234 \352\260\204\352\262\260\355\225\230\352\262\214 \354\236\221\354\204\261\355\225\264 \354\244\230. (\352\264\204\355\230\270\353\245\274 \354\263\220\354\204\234 \353\202\230\354\244\221\354\227\220 \354\210\230\354\240\225\355\225\230\352\270\260 \354\211\275\352\262\214)\n\n4. \354\230\210\353\260\260 \354\240\204 \354\240\220\352\262\200\354\202\254\355\225\255:\n- \354\230\210\353\260\260 10\353\266\204 \354\240\204 \353\217\204\354\260\251, \355\227\214\352\270\210/\354\204\261\352\262\275 \354\244\200\353\271\204, \352\270\260\353\217\204\353\241\234 \354\244\200\353\271\204\355\225\230\353\212\224 \353\247\210\354\235\214 \353\223\261 3\352\260\200\354\247\200 \354\262\264\355\201\254\353\246\254\354\212\244\355\212\270\353\245\274 \354\204\274\354\212\244 \354\236\210\353\212\224 \354\235\264\353\252\250\354\247\200\354\231\200 \355\225\250\352\273\230 \353\266\200\353\223\234\353\237\275\352\262\214 \352\266\214\353\251\264\355\225\264 \354\244\230.\n\n[\353\224\224\354\236\220\354\235\270 \352\260\200\354\235\264\353\223\234 & \354\266\234\353\240\245 \354\241\260\352\261\264]\n- \355\205\215\354\212\244\355\212\270 \354\240\204\354\262\264 \353\266\204\353\237\211\354\235\200 \354\212\244\353\247\210\355\212\270\355\217\260 \355\231\224\353\251\264 1\354\236\245\354\227\220 \354\227\254\353\260\261\354\235\204 \353\221\220\352\263\240 \353\223\244\354\226\264\352\260\210 \354\210\230 \354\236\210\353\217\204\353\241\235 \354\225\225\354\266\225\354\240\201\354\234\274\353\241\234 \354\236\221\354\204\261\355\225\240 \352\262\203.\n- \355\205\215\354\212\244\355\212\270 \354\266\234\353\240\245 \355\233\204 \355\225\230\353\213\250\354\227\220, \354\235\264 \353\202\264\354\232\251\354\235\204 \'\353\257\270\353\246\254\354\272\224\353\262\204\354\212\244\'\353\202\230 \'Canva(\354\272\224\353\260\224)\'\353\241\234 \354\240\234\354\236\221\355\225\240 \353\225\214 \354\262\255\354\206\214\353\205\204/\354\262\255\353\205\204\353\223\244\354\235\264 \354\242\213\354\225\204\355\225\240 \353\247\214\355\225\234 \354\225\204\353\236\230\354\235\230 \353\224\224\354\236\220\354\235\270 \355\214\201\354\235\204 \354\240\234\354\225\210\355\225\264 \354\244\230:\n  1) \354\240\204\354\262\264\354\240\201\354\235\270 \353\224\224\354\236\220\354\235\270 \353\254\264\353\223\234/\354\273\250\354\205\211 \354\240\234\354\225\210\n  2) \354\226\264\354\232\270\353\246\254\353\212\224 \355\212\270\353\240\214\353\224\224\355\225\234 \354\266\224\354\262\234 \355\217\260\355\212\270 (\354\240\234\353\252\251\354\232\251 / \353\263\270\353\254\270\354\232\251)\n  3) \354\266\224\354\262\234 \354\273\254\353\237\254 \355\214\224\353\240\210\355\212\270 (\353\251\224\354\235\270 \354\273\254\353\237\254 & \355\217\254\354\235\270\355\212\270 \354\273\254\353\237\254)\n"
    }
  }
}
