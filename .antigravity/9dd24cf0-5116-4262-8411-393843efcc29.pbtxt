  file_change {
    absolute_path_uri: "file:///src/presets.ts"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "export const DESIGN_THEMES: DesignTheme[] = [\n  {\n    id: \"theme-warm-cozy\",\n    name: \"\354\233\234 \354\275\224\354\247\200 \353\262\240\354\235\264\354\247\200 (Cafe Beige)\","
      replacement_content: "export const DESIGN_THEMES: DesignTheme[] = [\n  {\n    id: \"theme-bold-typography\",\n    name: \"\353\263\274\353\223\234 \355\203\200\354\235\264\355\217\254 & \353\240\210\355\212\270\353\241\234 \354\204\270\354\235\264\354\247\200 (Bold Sage)\",\n    description: \"\353\224\260\353\234\273\355\225\234 \354\235\274\354\203\201\354\235\230 \352\270\260\353\241\235 - \353\247\244\352\261\260\354\247\204 \352\260\220\354\204\261 \354\204\270\353\246\254\355\224\204\354\231\200 \354\260\250\353\266\204\355\225\234 \354\264\210\353\241\235 \354\227\220\353\224\224\354\205\230\",\n    concept: \"\354\235\270\353\223\234\355\203\200\352\267\270\353\236\250 \353\247\244\352\261\260\354\247\204\354\235\264\353\202\230 \353\224\224\354\236\220\354\235\270 \353\254\264\353\223\234\353\263\264\353\223\234\354\227\220\354\204\234 \354\230\201\352\260\220\354\235\204 \354\226\273\354\235\200 \353\240\210\354\235\264\354\225\204\354\233\203. \352\263\274\352\260\220\355\225\234 \355\217\260\355\212\270 \353\214\200\353\271\204\354\231\200 \354\275\224\354\247\200\355\225\234 \353\246\254\354\270\204\354\226\274 \354\204\270\354\235\264\354\247\200 \352\267\270\353\246\260(#7D8F69), \354\264\210\354\275\234\353\246\277 \353\270\214\353\235\274\354\232\264(#4A3728) \354\241\260\355\225\251\354\235\264 \354\204\270\354\213\254\355\225\230\352\263\240 \352\271\212\354\235\264 \354\236\210\353\212\224 \354\262\255\353\205\204\353\223\244\354\235\230 \352\260\220\354\210\230\354\204\261\354\235\204 \354\236\220\352\267\271\355\225\251\353\213\210\353\213\244.\",\n    bgColor: \"bg-[#F9F7F2]\",\n    textColor: \"text-[#4A3728]\",\n    accentBg: \"bg-[#7D8F69]\",\n    accentText: \"text-white\",\n    cardBg: \"bg-[#FDFCF9]\",\n    borderColor: \"border-stone-200/80\",\n    fontFamily: \"font-playfair\",\n    fontImportName: \"@import url(\'https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Noto+Sans+KR:wght@300;400;500;700&display=swap\');\",\n    fontNameKorean: \"\355\224\214\353\240\210\354\235\264\355\216\230\354\226\264 & \353\205\270\355\206\240\354\202\260\354\212\244 (Playfair Display & Noto Sans)\",\n    tagline: \"\353\224\260\354\212\244\355\225\234 \354\230\250\352\270\260\354\231\200 \354\236\241\354\247\200 \354\247\200\353\251\264\354\235\230 \354\225\204\353\246\204\353\213\244\354\232\264 \354\241\260\355\231\224\",\n    colors: [\n      { name: \"\354\204\270\354\235\264\354\247\200 \352\267\270\353\246\260 (Sage)\", hex: \"#7D8F69\", tailwind: \"bg-[#7D8F69]\", role: \"\354\230\244\355\224\204\353\213\235 \355\203\200\354\235\264\355\213\200 \353\260\217 \355\225\265\354\213\254 \354\273\264\355\217\254\353\204\214\355\212\270 \355\233\204\352\264\221\" },\n      { name: \"\353\202\264\354\266\224\353\237\264 \354\225\204\354\235\264\353\263\264\353\246\254\", hex: \"#F9F7F2\", tailwind: \"bg-[#F9F7F2]\", role: \"\354\247\200\353\251\264\354\235\230 \354\260\250\353\266\204\355\225\250\352\263\274 \355\201\254\353\246\254\353\257\270\355\225\234 \353\262\240\354\235\264\354\212\244 \354\240\234\352\263\265\" },\n      { name: \"\354\264\210\354\275\234\353\246\277 \353\270\214\353\235\274\354\232\264\", hex: \"#4A3728\", tailwind: \"bg-[#4A3728]\", role: \"\353\252\250\353\223\240 \355\205\215\354\212\244\355\212\270 \354\240\225\353\263\264\354\235\230 \354\240\225\352\260\210\355\225\234 \352\260\200\353\217\205\354\204\261 \353\263\264\354\231\204\" },\n      { name: \"\353\204\244\354\266\224\353\237\264 \354\247\204\354\240\200 \354\212\244\355\202\250\", hex: \"#F5F2ED\", tailwind: \"bg-[#F5F2ED]\", role: \"\354\225\214\353\246\274\355\214\220 \353\260\217 \352\263\265\354\247\200 \354\271\264\353\223\234\354\235\230 \353\266\200\353\223\234\353\237\254\354\232\264 \353\260\260\352\262\275\" }\n    ],\n    recommendedFonts: [\n      { target: \"\353\214\200\354\240\234\353\252\251 / \354\230\201\353\254\270 \354\212\254\353\241\234\352\261\264\", name: \"Playfair Display (Italic 700)\", details: \"\355\201\264\353\236\230\354\213\235\355\225\230\352\263\240 \354\204\270\353\240\250\353\220\234 \354\230\201\353\254\270 \354\205\260\353\246\254\355\224\204. \354\212\244\355\206\240\353\246\254 \354\247\200\353\251\264 \353\260\217 \354\243\274\353\263\264\354\235\230 \352\260\225\353\240\245\355\225\234 \354\235\270\354\203\201 \354\204\240\354\202\254\" },\n      { target: \"\353\263\270\353\254\270 \352\265\254\354\240\210 \353\260\217 \353\224\224\355\205\214\354\235\274\", name: \"\353\247\221\354\235\200 \352\263\240\353\224\224 / \353\235\274\354\235\270 \352\263\240\353\224\225 / Noto Sans KR\", details: \"\353\210\210\354\227\220 \353\266\210\355\216\270\355\225\250 \354\227\206\354\235\264 \353\247\244\353\240\245\354\235\204 \352\260\200\354\236\245 \354\230\250\354\240\204\355\236\210 \354\240\204\355\225\264\354\243\274\353\212\224 \355\230\204\353\214\200\354\213\235 \354\204\234\354\262\264\" }\n    ]\n  },\n  {\n    id: \"theme-warm-cozy\",\n    name: \"\354\233\234 \354\275\224\354\247\200 \353\262\240\354\235\264\354\247\200 (Cafe Beige)\","
