        lines {
          text: "    content: \"\354\210\250\352\260\200\354\201\230\352\262\214 \353\213\254\353\240\244\354\230\250 \355\225\234 \354\243\274\354\235\230 \355\206\240\354\232\224\354\235\274 \354\240\200\353\205\201. \354\204\270\354\203\201\354\235\230 \354\206\214\354\235\214\354\235\200 \354\236\240\354\213\234 \352\272\274\353\221\224 \354\261\204, \354\236\210\353\212\224 \353\252\250\354\212\265 \352\267\270\353\214\200\353\241\234 \353\202\230\354\231\200\354\204\234 \355\216\270\355\236\210 \354\211\254\354\226\264\352\260\224\354\234\274\353\251\264 \354\242\213\352\262\240\354\226\264. \353\202\264\354\235\274 \354\230\210\353\260\260\355\225\230\353\212\224 \354\235\264\352\263\263\354\235\264 \353\204\210\354\235\230 \353\224\260\353\234\273\355\225\234 \354\211\274\355\221\234\354\235\264\352\270\260\353\245\274. \342\230\225\357\270\217\""
