      replacement_content: "import React, { useState } from \"react\";\nimport { BulletinData, DesignTheme } from \"../types\";\nimport { \n  Smartphone, \n  MessageSquare, \n  Music, \n  User, \n  BookOpen, \n  Flame, \n  Heart,\n  Instagram,\n  CheckCircle2,\n  Calendar,\n  Layers,\n  ChevronRight,\n  Share2\n} from \"lucide-react\";\n\ninterface MobilePreviewProps {\n  data: BulletinData;\n  activeTheme: DesignTheme;\n}\n\nexport default function MobilePreview({ data, activeTheme }: MobilePreviewProps) {\n  const [viewMode, setViewMode] = useState<\"card\" | \"kakao\">(\"card\");\n\n  // Format worship order sequence cleanly for text copy\n  const praiseList = data.praiseSongs;\n\n  return (\n    <div className=\"flex flex-col items-center gap-4 py-2\" id=\"mobile-preview-container\">\n      \n      {/* View Mode Selector */}\n      <div className=\"flex bg-slate-200/80 p-1.5 rounded-xl gap-1 shrink-0 w-full max-w-[340px]\">\n        <button\n          onClick={() => setViewMode(\"card\")}\n          className={`flex-1 py-1 px-3 text-xs font-bold rounded-lg transition-all flex items-center justify-center gap-1.5 ${\n            viewMode === \"card\"\n              ? \"bg-white text-slate-800 shadow-xs\"\n              : \"text-slate-500 hover:text-slate-800\"\n          }`}\n          id=\"toggle-view-card\"\n        >\n          <Smartphone className=\"w-3.5 h-3.5\" />\n          <span>\352\260\220\354\204\261 \354\247\200\353\251\264 \354\271\264\353\223\234\353\267\260</span>\n        </button>\n        \n        <button\n          onClick={() => setViewMode(\"kakao\")}\n          className={`flex-1 py-1 px-3 text-xs font-bold rounded-lg transition-all flex items-center justify-center gap-1.5 ${\n            viewMode === \"kakao\"\n              ? \"bg-white text-slate-800 shadow-xs\"\n              : \"text-slate-500 hover:text-slate-800\"\n          }`}\n          id=\"toggle-view-kakao\"\n        >\n          <MessageSquare className=\"w-3.5 h-3.5\" />\n          <span>\354\271\264\354\271\264\354\230\244\355\206\241 \354\240\204\354\206\241\353\267\260</span>\n        </button>\n      </div>\n\n      {/* Smartphone Outer Shell Mockup */}\n      <div className=\"relative w-full max-w-[350px] aspect-[9/19.5] bg-slate-950 rounded-[40px] p-2.5 shadow-2xl border-4 border-slate-800 ring-8 ring-slate-900 ring-offset-2 ring-offset-slate-100 flex flex-col overflow-hidden\">\n        \n        {/* Smartphone Speaker Sensor Notch */}\n        <div className=\"absolute top-2.5 left-1/2 -translate-x-1/2 w-32 h-4.5 bg-black rounded-b-2xl z-50 flex items-center justify-center\">\n          <div className=\"w-12 h-1 bg-neutral-800 rounded-full mb-1\"></div>\n        </div>\n\n        {/* Smartphone Status Bar Area */}\n        <div className=\"flex justify-between items-center px-6 pt-3.5 pb-1 text-black/85 z-40 text-[10px] font-mono shrink-0 font-medium\">\n          <span className={viewMode === \"card\" && activeTheme.id === \"theme-deep-space\" ? \"text-slate-400\" : \"text-slate-600\"}>\n            20:00 Sat\n          </span>\n          <div className=\"flex items-center gap-1\">\n            <span className={`w-3 h-1.5 rounded-xs border ${viewMode === \"card\" && activeTheme.id === \"theme-deep-space\" ? \"border-slate-500 bg-emerald-500\" : \"border-slate-800 bg-emerald-600\"}`}></span>\n            <span className={viewMode === \"card\" && activeTheme.id === \"theme-deep-space\" ? \"text-slate-400\" : \"text-slate-600\"}>\n              LTE\n            </span>\n          </div>\n        </div>\n\n        {/* INTERNALS OF SCREEN */}\n        <div className=\"flex-1 rounded-[32px] overflow-hidden relative flex flex-col\">\n          \n          {/* VIEW: Card (Canva Graphic Design Theme Preview) */}\n          {viewMode === \"card\" && (\n            <div \n              style={{ fontFamily: activeTheme.fontFamily.replace(\"font-[\", \"\").replace(\"]\", \"\") }}\n              className={`flex-1 overflow-y-auto ${activeTheme.bgColor} ${activeTheme.textColor} p-5 pb-12 flex flex-col gap-6 relative select-none scrollbar-thin`}\n              id=\"card-mode-view\"\n            >\n              {/* Star decoration for Deep dark theme */}\n              {activeTheme.id === \"theme-deep-space\" && (\n                <div className=\"absolute inset-0 overflow-hidden pointer-events-none opacity-20\">\n                  <span className=\"absolute top-10 left-12 w-1.5 h-1.5 bg-white rounded-full animate-pulse\"></span>\n                  <span className=\"absolute top-48 right-16 w-1 h-1 bg-white rounded-full\"></span>\n                  <span className=\"absolute bottom-28 left-8 w-2 h-2 bg-yellow-200 rounded-full animate-ping\"></span>\n                  <span className=\"absolute top-[350px] right-24 w-1 h-1 bg-white rounded-full\"></span>\n                </div>\n              )}\n\n              {/* Card Header decoration */}\n              <div className=\"text-center pt-2 shrink-0\">\n                <div className=\"inline-flex items-center justify-center gap-1 text-[9px] tracking-[0.25em] font-bold uppercase py-1 px-3 border-b border-rose-400/30 font-mono\">\n                  <span>\342\200\240</span>\n                  <span>Youth Ministry</span>\n                </div>\n                <div className=\"text-[10px] font-bold tracking-wider mt-1 opacity-70\">\n                  SUNDAY WORSHIP BULLETIN\n                </div>\n              </div>\n\n              {/* Section 1: Opening Greeting */}\n              <div className=\"text-center space-y-2.5 shrink-0\">\n                <h1 className=\"text-base font-bold tracking-tight px-1 leading-relaxed text-balance\">\n                  {data.greetingTitle}\n                </h1>\n                \n                <div className={`p-4 rounded-2xl ${activeTheme.cardBg} border ${activeTheme.borderColor} shadow-xs text-xs leading-relaxed text-left relative`}>\n                  {/* Small double quote decos */}\n                  <span className=\"text-2xl font-serif text-teal-400/40 absolute -top-1 -left-1\">\342\200\234</span>\n                  <div className=\"relative z-10 px-1 pt-1 break-keep text-[11px] opacity-90 whitespace-pre-line\">\n                    {data.greetingContent}\n                  </div>\n                  <span className=\"text-2xl font-serif text-teal-400/40 absolute bottom-0 right-1 leading-none\">\342\200\235</span>\n                </div>\n              </div>\n\n              {/* Section 2: Worship Order List */}\n              <div className={`p-4 rounded-2xl ${activeTheme.cardBg} border ${activeTheme.borderColor} shadow-xs space-y-4`}>\n                <div className=\"flex items-center justify-between border-b border-slate-100 pb-2\">\n                  <h3 className=\"text-xs font-bold tracking-wider flex items-center gap-1.2 font-mono\">\n                    <span>\342\234\235</span> SCHEDULE OF WORSHIP\n                  </h3>\n                  <span className=\"text-[9px] font-bold opacity-60\">\354\243\274\354\235\274 \353\266\200\354\204\234 \354\230\210\353\260\260\354\210\234\354\204\234</span>\n                </div>\n\n                <div className=\"space-y-3.5 text-xs\">\n                  \n                  {/* Praise list */}\n                  <div className=\"space-y-1.5\">\n                    <div className=\"flex items-center gap-1.5\">\n                      <div className={`w-5 h-5 rounded-full ${activeTheme.accentBg} ${activeTheme.accentText} flex items-center justify-center shrink-0`}>\n                        <Music className=\"w-3 h-3\" />\n                      </div>\n                      <span className=\"font-bold text-[11px] tracking-wide\">\354\260\254\354\226\221\352\263\274 \352\262\275\353\260\260 (Praise)</span>\n                    </div>\n                    <ul className=\"pl-6 space-y-1\">\n                      {praiseList.map((song, i) => (\n                        <li key={i} className=\"text-[10.5px] opacity-80 flex items-start gap-1\">\n                          <span className=\"text-teal-500 font-mono\">\342\200\242</span>\n                          <span className=\"break-all\">{song}</span>\n                        </li>\n                      ))}\n                    </ul>\n                  </div>\n\n                  {/* Prayer */}\n                  <div className=\"flex justify-between items-center text-[11px] border-t border-slate-100/60 pt-2 pb-0.5\">\n                    <span className=\"opacity-80 flex items-center gap-1\">\n                      <User className=\"w-3.5 h-3.5 opacity-60 text-teal-500\" />\n                      <span>\353\214\200\355\221\234\352\270\260\353\217\204 (Prayer)</span>\n                    </span>\n                    <span className=\"font-bold\">{data.prayerLeader}</span>\n                  </div>\n\n                  {/* Announcement header */}\n                  <div className=\"flex justify-between items-center text-[11px] border-t border-slate-100/60 pt-2 pb-0.5\">\n                    <span className=\"opacity-80 flex items-center gap-1\">\n                      <ChevronRight className=\"w-3.5 h-3.5 opacity-60 text-teal-500\" />\n                      <span>\352\265\220\354\240\234 \353\260\217 \354\206\214\354\213\235</span>\n                    </span>\n                    <span className=\"font-bold\">\354\236\204\354\233\220\354\247\204</span>\n                  </div>\n\n                  {/* Scripture Reading */}\n                  <div className=\"flex justify-between items-center text-[11px] border-t border-slate-100/60 pt-2 pb-0.5\">\n                    <span className=\"opacity-80 flex items-center gap-1\">\n                      <BookOpen className=\"w-3.5 h-3.5 opacity-60 text-teal-500\" />\n                      <span>\353\247\220\354\224\200\353\264\211\353\217\205 (Scripture)</span>\n                    </span>\n                    <span className=\"font-semibold text-teal-600 truncate max-w-[140px] text-right\" title={data.bibleVerse}>\n                      {data.bibleVerse}\n                    </span>\n                  </div>\n\n                  {/* Worship Offering */}\n                  <div className=\"flex justify-between items-center text-[11px] border-t border-slate-100/60 pt-2 pb-0.5\">\n                    <span className=\"opacity-80 flex items-center gap-1\">\n                      <ChevronRight className=\"w-3.5 h-3.5 opacity-60 text-teal-500\" />\n                      <span>\353\264\211\355\227\214\352\263\274 \352\260\220\354\202\254\354\235\230 \352\270\260\353\217\204</span>\n                    </span>\n                    <span className=\"font-bold\">\354\230\250 \355\232\214\354\244\221</span>\n                  </div>\n\n                  {/* Sermon Box */}\n                  <div className=\"border-t border-slate-100/65 pt-3 mt-1 text-center bg-slate-50/50 -mx-4 px-4 py-2.5 space-y-1\">\n                    <span className=\"text-[9px] font-bold text-teal-600 bg-teal-50 px-2 py-0.5 rounded-full inline-block\">\n                      TODAY\'S MESSAGE\n                    </span>\n                    <h4 className=\"font-bold text-[11.5px] leading-snug tracking-tight text-slate-800 px-1 dark:text-slate-100\">\n                      \343\200\214{data.sermonTitle}\343\200\215\n                    </h4>\n                    <p className=\"text-[10px] opacity-70\">\n                      \354\204\244\352\265\220: {data.preacher}\n                    </p>\n                  </div>\n\n                  {/* Decision */}\n                  <div className=\"flex items-start gap-2 border-t border-slate-100/60 pt-3 mt-1\">\n                    <div className=\"w-5 h-5 rounded-full bg-amber-100 text-amber-700 flex items-center justify-center shrink-0\">\n                      <Flame className=\"w-3.5 h-3.5\" />\n                    </div>\n                    <div className=\"min-w-0 flex-1\">\n                      <span className=\"font-bold text-[10px] block text-amber-800\">\352\262\260\353\213\250\354\235\230 \354\204\240\354\226\270 (Response)</span>\n                      <p className=\"text-[10px] opacity-80 leading-relaxed italic\">{data.decisionText}</p>\n                    </div>\n                  </div>\n\n                </div>\n              </div>\n\n              {/* Section 3: Ministry Instagram Feed Ads */}\n              <div className=\"space-y-3.5 shrink-0\">\n                <div className=\"flex items-center gap-1.5 px-0.5\">\n                  <Instagram className=\"w-4 h-4 text-pink-500\" />\n                  <h3 className=\"text-xs font-bold tracking-tight\">\354\235\264\353\262\210 \354\243\274 \354\206\214\354\213\235 (Insta)</h3>\n                </div>\n\n                <div className=\"space-y-3\">\n                  {data.announcements.map((ann, idx) => (\n                    <div \n                      key={ann.id}\n                      className={`rounded-2xl overflow-hidden border ${activeTheme.borderColor} ${activeTheme.cardBg} shadow-xs`}\n                    >\n                      {/* Insta Mock Header */}\n                      <div className=\"p-3 bg-slate-50/40 border-b border-slate-100 flex items-center justify-between\">\n                        <div className=\"flex items-center gap-2\">\n                          <div className=\"w-6 h-6 rounded-full bg-indigo-500 text-white font-serif flex items-center justify-center text-[10px] italic font-bold shrink-0\">\n                            Y\n                          </div>\n                          <div className=\"min-w-0\">\n                            <span className=\"text-[10px] font-bold block leading-none\">\354\232\260\353\246\254\353\223\244 \354\262\255\353\205\204\353\266\200</span>\n                            <span className=\"text-[8px] opacity-40\">@weekly_youth</span>\n                          </div>\n                        </div>\n                        <span className=\"text-[10px] opacity-30\">\360\237\222\231</span>\n                      </div>\n\n                      {/* Insta Content Body */}\n                      <div className=\"p-3.5 space-y-1.5\">\n                        <h4 className=\"text-[11.5px] font-extrabold text-slate-800 tracking-tight leading-snug\">\n                          {ann.title}\n                        </h4>\n                        <p className=\"text-[10.5px] leading-relaxed text-slate-600 whitespace-pre-line\">\n                          {ann.content}\n                        </p>\n                        <span className=\"text-[10px] text-teal-600 font-bold block mt-1.5 font-mono\">\n                          {ann.tag}\n                        </span>\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              </div>\n\n              {/* Section 4: Pre-worship Checklist */}\n              <div className={`p-4 rounded-2xl ${activeTheme.cardBg} border ${activeTheme.borderColor} shadow-xs space-y-3 shrink-0`}>\n                <div className=\"flex items-center gap-1.5 border-b border-slate-100 pb-1.5\">\n                  <CheckCircle2 className=\"w-4 h-4 text-emerald-500\" />\n                  <h3 className=\"text-xs font-bold tracking-tight\">\354\230\210\353\260\260 \354\240\204 \354\235\200\355\230\234 \354\261\204\354\232\260\352\270\260 \354\262\264\355\201\254\353\246\254\354\212\244\355\212\270</h3>\n                </div>\n\n                <ul className=\"space-y-3\">\n                  {data.checklists.map((chk) => (\n                    <li key={chk.id} className=\"flex gap-2.5 items-start\">\n                      <span className=\"text-sm shrink-0 bg-slate-50 w-6 h-6 rounded-lg flex items-center justify-center border border-slate-150\">\n                        {chk.emoji}\n                      </span>\n                      <div className=\"min-w-0\">\n                        <strong className=\"text-[10.5px] font-bold text-slate-800 leading-none block\">{chk.text}</strong>\n                        <span className=\"text-[9.5px] text-slate-400 leading-snug block mt-0.5 break-keep\">\n                          {chk.subtext}\n                        </span>\n                      </div>\n                    </li>\n                  ))}\n                </ul>\n              </div>\n\n              {/* Card Footer branding */}\n              <div className=\"text-center pt-2 pb-4 opacity-40\">\n                <p className=\"text-[9px] font-mono\">\354\230\210\353\260\260\354\227\220 \353\247\210\354\235\214\354\235\204 \353\213\264\353\212\224 \353\213\271\354\213\240\354\235\264 \352\260\200\354\236\245 \354\206\214\354\244\221\355\225\251\353\213\210\353\213\244.</p>\n              </div>\n\n            </div>\n          )}\n\n          {/* VIEW: KakaoTalk Chat (Classic Bubble Mockup) */}\n          {viewMode === \"kakao\" && (\n            <div className=\"flex-1 overflow-y-auto bg-[#BACEE0] p-4 flex flex-col font-sans select-text scrollbar-thin\" id=\"kakao-mode-view\">\n              \n              {/* Chat Date Divider */}\n              <div className=\"mx-auto my-3 bg-black/10 text-white text-[9.5px] py-1 px-3 rounded-full text-center tracking-tight\">\n                2026\353\205\204 6\354\233\224 13\354\235\274 \355\206\240\354\232\224\354\235\274\n              </div>\n\n              {/* Profile Wrapper */}\n              <div className=\"flex gap-2.5 mt-2\">\n                <div className=\"w-9 h-9 rounded-2xl bg-teal-600 text-white flex items-center justify-center shrink-0 shadow-xs font-bold text-xs select-none\">\n                  \342\234\235\357\270\217\n                </div>\n                \n                <div className=\"flex flex-col gap-1 items-start min-w-0 flex-1\">\n                  <span className=\"text-[10.5px] text-slate-700 font-bold select-none\">\n                    \355\226\211\353\263\265\355\225\234 \354\232\260\353\246\254 \354\262\255\353\205\204\353\266\200 (Mobile Bulletin)\n                  </span>\n                  \n                  {/* Chat Bubble card */}\n                  <div className=\"bg-white text-slate-900 rounded-tr-xl rounded-b-xl px-3.5 py-3 shadow-xs border border-slate-200/50 max-w-[240px] text-[10.5px] leading-relaxed whitespace-pre-wrap select-all selection:bg-teal-100 font-mono\">\n                    <span className=\"text-rose-500 font-bold block mb-1\">\360\237\214\237 [\354\243\274\354\235\274 \354\230\210\353\260\260 \353\252\250\353\260\224\354\235\274 \354\243\274\353\263\264] \360\237\214\237</span>\n                     \n                    <strong className=\"block text-slate-800\">\360\237\222\254 \354\230\244\353\212\230\354\235\230 \353\213\244\354\240\225\355\225\234 \354\235\270\354\202\254</strong>\n                    \"{data.greetingTitle}\"<br/>\n                    {data.greetingContent}<br/>\n                    \n                    \342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201<br/>\n                    \342\233\252\357\270\217 \353\217\214\354\225\204\354\230\244\353\212\224 \354\243\274\354\235\274 \354\230\210\353\260\260 \354\210\234\354\204\234<br/>\n                    \342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201<br/>\n                    \342\200\242 \360\237\216\265 \354\260\254\354\226\221\352\263\274 \352\262\275\353\260\260<br/>\n                    {praiseList.map((song, i) => `   ${i + 1}. ${song}`).join(\"\\n\")}<br/><br/>\n                    \n                    \342\200\242 \360\237\231\217 \353\214\200\355\221\234\352\270\260\353\217\204: {data.prayerLeader}<br/>\n                    \342\200\242 \360\237\223\226 \353\247\220\354\224\200\353\264\211\353\217\205: {data.bibleVerse}<br/>\n                    \342\200\242 \360\237\223\226 \353\247\220\354\224\200\354\204\240\355\217\254:<br/>\n                     [{data.sermonTitle}] - {data.preacher}<br/>\n                    \342\200\242 \360\237\224\245 \352\262\260\353\213\250\354\235\230 \352\263\240\353\260\261: {data.decisionText}<br/>\n                    \n                    \342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201<br/>\n                    \360\237\223\214 \354\235\264\353\262\210 \354\243\274 \354\232\260\353\246\254 \353\266\200\354\204\234 \354\206\214\354\213\235 (Insta)<br/>\n                    \342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201<br/>\n                    {data.announcements.map((ann, i) => \n                      `[\354\206\214\354\213\235 ${i+1}] ${ann.title}\\n  - ${ann.content.slice(0, 40)}...\\n  ${ann.tag}`\n                    ).join(\"\\n\\n\")}<br/>\n                    <br/>\n                    \342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201<br/>\n                    \360\237\222\241 \354\235\200\355\230\234 \353\204\230\354\271\230\353\212\224 \354\230\210\353\260\260 \354\240\204 \354\240\220\352\262\200\354\202\254\355\225\255<br/>\n                    \342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201<br/>\n                    {data.checklists.map((chk, i) => \n                      `${chk.emoji} ${chk.text}`\n                    ).join(\"\\n\")}<br/>\n                    <br/>\n                    \353\202\264\354\235\274 \354\230\210\353\260\260\354\227\220\354\204\234 \353\247\214\353\202\230\354\232\224! \360\237\244\215\n                  </div>\n                  \n                  <span className=\"text-[8px] text-slate-500 ml-1 self-start select-none\">\n                    \354\230\244\355\233\204 8:12\n                  </span>\n                </div>\n              </div>\n\n            </div>\n          )}\n\n        </div>\n      </div>\n\n    </div>\n  );\n}\n"
    }
